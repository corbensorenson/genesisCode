      "guard_checks": [
        "scripts/check_green_front_door.sh",
        "scripts/check_check_update_boundary.sh",
        "scripts/check_capability_evidence_ledger_contract.sh"
      ],
      "negative_controls": [
        "reject autonomous changes to governance roots, self-approval, benchmark overfitting, and v1 compatibility regressions"
      ]
    }
