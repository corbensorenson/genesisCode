{
  "kind": "genesis/roadmap-execution-policy-v0.1",
  "version": "0.1",
  "audit_date": "2026-07-15",
  "resource_classes": [
    "static",
    "build",
    "benchmark",
    "proof",
    "release",
    "research"
  ],
  "risk_classes": {
    "low": {
      "negative_controls": [
        "reject roadmap/manifest coverage or generated-view drift"
      ],
      "rollback": "Revert the reviewed source change, regenerate derived views, and preserve the rejected diff as evidence."
    },
    "medium": {
      "negative_controls": [
        "reject missing prerequisites, acceptance evidence, or source identities",
        "reject undeclared output and compatibility changes"
      ],
      "rollback": "Restore the prior compatible artifact or profile, rerun its guards, and retain the failed candidate for diagnosis."
    },
    "high": {
      "negative_controls": [
        "reject stale identities, unknown fields, host-specific paths, and evidence produced by update commands",
        "reject capability, policy, format, or resource broadening without an explicit reviewed contract"
      ],
      "rollback": "Fail closed, keep the prior verified authority reachable, reverse only through a reviewed semantic patch, and preserve all mismatch evidence."
    },
    "critical": {
      "negative_controls": [
        "reject any semantic, authority, seal, replay, capability, bootstrap, or release-policy bypass",
        "reject self-verification, unsigned authority changes, and incomplete independent evidence"
      ],
      "rollback": "Fail closed before authority changes, retain the last independently verified implementation and trust roots, revoke affected artifacts when necessary, and require incident evidence before resumption."
    }
  },
  "execution_profiles": {
    "planning-truth": {
      "risk_class": "high",
      "resource_class": "static",
      "owner_paths": [
        "ROADMAP.md",
        "upgrade_plan.md",
        "feature_matrix.md",
        "docs/status",
        "scripts/lib"
      ],
      "guard_checks": [
        "scripts/check_planning_docs_fresh.sh",
        "scripts/check_doc_topology_drift.sh",
        "scripts/check_capability_evidence_ledger_contract.sh"
      ],
      "negative_controls": [
        "reject duplicate, missing, reordered, or self-completing roadmap task records"
      ]
    },
    "evidence-authority": {
      "risk_class": "critical",
      "resource_class": "static",
      "owner_paths": [
        "docs/spec",
        "docs/program",
        "policies",
        "scripts"
      ],
      "guard_checks": [
        "scripts/check_check_update_boundary.sh",
        "scripts/check_generated_artifact_policy.sh",
        "scripts/check_capability_evidence_ledger_contract.sh"
      ],
      "negative_controls": [
        "reject a check that mutates retained evidence or treats freshly produced material as independent proof"
      ]
    },
    "hermetic-foundation": {
      "risk_class": "high",
      "resource_class": "build",
      "owner_paths": [
        "Cargo.toml",
        "Cargo.lock",
        "genesis.lock",
        "policies",
        "scripts"
      ],
      "guard_checks": [
        "scripts/check_root_lock_policy.sh",
        "scripts/check_versioning_release_hygiene.sh",
        "scripts/check_supply_chain.sh"
      ],
      "negative_controls": [
        "reject undeclared tools, network inputs, rebuild islands, and benchmark environments"
      ]
    },
    "agent-contract": {
      "risk_class": "high",
      "resource_class": "build",
      "owner_paths": [
        ".agents",
        "docs/skill_pack",
        "docs/spec",
        "examples",
        "scripts"
      ],
      "guard_checks": [
        "scripts/check_agent_authoring_bundle.sh",
        "scripts/check_cli_diagnostics_contract.sh",
        "scripts/check_write_genesiscode_skill_conformance.sh"
      ],
      "negative_controls": [
        "reject stale cards, prompt-injected authority, policy broadening, and training/evaluation leakage"
      ]
    },
    "runtime-core": {
      "risk_class": "critical",
      "resource_class": "benchmark",
      "owner_paths": [
        "crates/gc_kernel",
        "crates/gc_effects",
        "crates/gc_prelude",
