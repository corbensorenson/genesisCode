        "scripts/check_green_front_door.sh",
        "scripts/check_supply_chain.sh"
      ],
      "negative_controls": [
        "reject unreproduced artifacts, unsigned claims, incompatible upgrades, compromised roots, and release evidence verified only by its producer"
      ]
    },
    "frontier-research": {
      "risk_class": "critical",
      "resource_class": "research",
      "owner_paths": [
        "ROADMAP.md",
        "docs/program",
        "docs/spec",
        "policies",
        "scripts"
