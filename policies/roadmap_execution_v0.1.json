      ],
      "negative_controls": [
        "reject tier divergence, resource-accounting bypass, host leaks, unbounded allocation, and user-reachable panic"
      ]
    },
    "validated-tier": {
      "risk_class": "critical",
      "resource_class": "build",
      "owner_paths": [
        "crates/gc_kernel",
