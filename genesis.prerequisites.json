    },
    {
      "constraint": {
        "exact": "1.8.0"
      },
      "id": "rustfmt",
      "probe": {
        "argv": [
          "rustfmt",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "rustfmt ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Canonical Rust source formatting",
      "source": "rust-toolchain.toml"
    },
    {
      "constraint": {
        "exact": "0.10.0"
      },
      "id": "shellcheck",
      "probe": {
        "argv": [
          "shellcheck",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "version: ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Optional shell static analysis",
      "source": "developer/CI hygiene"
    },
    {
      "constraint": {
        "exact": "33.0"
      },
      "id": "wasi-sdk",
      "probe": {
        "argv": [
          "bash",
          "scripts/install_wasi_sdk.sh",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "wasi-sdk ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Pinned WASI C/C++ compiler and libc sysroot for native dependencies",
