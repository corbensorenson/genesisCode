      "probe": {
        "argv": [
          "ios-deploy",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Optional physical iOS application deployment",
      "source": "scripts/render_gcpm_target_runtime_pipelines_report.sh"
    },
    {
      "constraint": {
        "minInclusive": "1.6.0",
        "maxExclusive": "2.0.0"
      },
      "id": "jq",
      "probe": {
        "argv": [
          "jq",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "jq-([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Optional local JSON inspection; production checks must not depend on it",
      "source": "developer convenience"
    },
    {
      "constraint": {
        "exact": "5.0.0"
      },
      "id": "lake",
      "probe": {
        "argv": [
          "lake",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "Lake version ([0-9]+(?:\\.[0-9]+){0,2})"
