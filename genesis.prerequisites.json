    },
    {
      "constraint": {
        "exact": "4.31.0"
      },
      "id": "lean",
      "probe": {
        "argv": [
          "lean",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "version ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Mechanized language, seal, replay, bytecode, and concurrency proofs",
      "source": "ROADMAP.md#R7.2"
    },
    {
      "constraint": {
        "minInclusive": "22.0.0",
        "maxExclusive": "23.0.0"
      },
      "id": "node",
      "probe": {
        "argv": [
          "node",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "v([0-9]+(?:\\.[0-9]+){0,2})"
