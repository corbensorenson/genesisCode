    },
    {
      "constraint": {
        "exact": "1.90.0"
      },
      "id": "rust-target-wasm32-wasip1",
      "probe": {
        "kind": "rustup-target",
        "target": "wasm32-wasip1"
      },
      "purpose": "WASI Preview 1 command builds",
      "source": "rust-toolchain.toml"
    },
    {
      "constraint": {
        "exact": "1.90.0"
      },
      "id": "rustc",
      "probe": {
        "argv": [
          "rustc",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "rustc ([0-9]+(?:\\.[0-9]+){0,2})"
