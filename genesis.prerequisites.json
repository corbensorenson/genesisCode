{
  "kind": "genesis/prerequisite-manifest-v0.1",
  "version": "0.1",
  "profiles": [
    {
      "description": "Android application/device development with the command-line SDK platform tools.",
      "id": "android-device",
      "optional": [],
      "requireNativeSdk": true,
      "requires": [
        "adb"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    },
    {
      "description": "Apple application/device development in addition to the native SDK.",
      "id": "apple-device",
      "optional": [
        "idevice-id",
        "ios-deploy"
      ],
      "requireNativeSdk": true,
      "requires": [
        "xcodebuild",
        "xcrun"
      ],
      "platformIds": [
        "darwin-arm64"
      ]
    },
    {
      "description": "Pinned standard CI test and supply-chain tooling.",
      "id": "ci",
      "optional": [],
      "requireNativeSdk": true,
      "requires": [
        "bash",
        "cargo",
        "cargo-deny",
        "cargo-nextest",
        "clippy",
        "git",
        "jq",
        "python",
        "rustc",
        "rustfmt"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    },
    {
      "description": "Minimum supported local build, format, check, and deterministic native execution environment.",
      "id": "core",
      "optional": [
        "cargo-nextest",
        "jq",
        "shellcheck"
      ],
      "requireNativeSdk": true,
      "requires": [
        "bash",
        "cargo",
        "clippy",
        "git",
        "python",
        "rustc",
        "rustfmt"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    },
    {
      "description": "Lean 4 formal models and Lake-managed proof checks.",
      "id": "formal",
      "optional": [],
      "requireNativeSdk": false,
      "requires": [
        "git",
        "lake",
        "lean"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    },
    {
      "description": "Union of release-relevant core, CI, web, WASI, and formal prerequisites; device and fuzz profiles remain explicit opt-ins.",
      "id": "full",
      "optional": [
        "shellcheck"
      ],
      "requireNativeSdk": true,
      "requires": [
        "bash",
        "cargo",
        "cargo-deny",
        "cargo-nextest",
        "clippy",
        "git",
        "jq",
        "lake",
        "lean",
        "node",
        "npm",
        "playwright",
        "python",
        "rust-target-wasm32-unknown-unknown",
        "rust-target-wasm32-wasip1",
        "rustc",
        "rustfmt",
        "wasi-sdk",
        "wasm-bindgen",
        "wasmtime"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    },
    {
      "description": "Rust fuzzing and mutation-corpus development.",
      "id": "fuzz",
      "optional": [
        "cargo-nextest"
      ],
      "requireNativeSdk": true,
      "requires": [
        "cargo",
        "cargo-fuzz",
        "clang",
        "rustc"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64"
      ]
    },
    {
      "description": "WASI Preview 1 CLI build and Wasmtime parity tests.",
      "id": "wasi",
      "optional": [],
      "requireNativeSdk": true,
      "requires": [
        "bash",
        "cargo",
        "python",
        "rust-target-wasm32-wasip1",
        "rustc",
        "wasi-sdk",
        "wasmtime"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    },
    {
      "description": "Browser and Node WebAssembly bindings, deterministic cross-host checks, and Playwright browser tests.",
      "id": "web",
      "optional": [],
      "requireNativeSdk": true,
      "requires": [
        "bash",
        "cargo",
        "node",
        "npm",
        "playwright",
        "python",
        "rust-target-wasm32-unknown-unknown",
        "rustc",
        "wasm-bindgen"
      ],
      "platformIds": [
        "darwin-arm64",
        "linux-arm64",
        "linux-x86-64",
        "windows-x86-64"
      ]
    }
  ],
  "platforms": [
    {
      "architecture": "arm64",
      "id": "darwin-arm64",
      "operatingSystem": "darwin",
      "probes": [
        {
          "argv": [
            "xcrun",
            "clang",
            "--version"
          ],
          "constraint": {
            "minInclusive": "16.0.0",
            "maxExclusive": "17.0.0"
          },
          "id": "apple-clang",
          "versionRegex": "Apple clang version ([0-9]+(?:\\.[0-9]+){0,2})"
        },
        {
          "argv": [
            "xcrun",
            "--sdk",
            "macosx",
            "--show-sdk-version"
          ],
          "constraint": {
            "minInclusive": "15.2.0",
            "maxExclusive": "16.0.0"
          },
          "id": "macos-sdk",
          "versionRegex": "^([0-9]+(?:\\.[0-9]+){0,2})$"
        },
        {
          "argv": [
            "xcodebuild",
            "-version"
          ],
          "constraint": {
            "minInclusive": "16.2.0",
            "maxExclusive": "17.0.0"
          },
          "id": "xcode",
          "versionRegex": "Xcode ([0-9]+(?:\\.[0-9]+){0,2})"
        }
      ],
      "tier": 1
    },
    {
      "architecture": "arm64",
      "id": "linux-arm64",
      "operatingSystem": "linux",
      "probes": [
        {
          "argv": [
            "cc",
            "--version"
          ],
          "constraint": null,
          "id": "c-compiler",
          "versionRegex": null
        }
      ],
      "tier": 2
    },
    {
      "architecture": "x86_64",
      "id": "linux-x86-64",
      "operatingSystem": "linux",
      "probes": [
        {
          "argv": [
            "cc",
            "--version"
          ],
          "constraint": null,
          "id": "c-compiler",
          "versionRegex": null
        }
      ],
      "tier": 1
    },
    {
      "architecture": "x86_64",
      "id": "windows-x86-64",
      "operatingSystem": "windows",
      "probes": [
        {
          "argv": [
            "cl",
            "/Bv"
          ],
          "constraint": null,
          "id": "msvc",
          "versionRegex": null
        }
      ],
      "tier": 2
    }
  ],
  "tools": [
    {
      "constraint": {
        "minInclusive": "1.0.41",
        "maxExclusive": "2.0.0"
      },
      "id": "adb",
      "probe": {
        "argv": [
          "adb",
          "version"
        ],
        "kind": "command-version",
        "versionRegex": "Android Debug Bridge version ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Android device bridge and emulator/device deployment",
      "source": "Android SDK Platform-Tools"
    },
    {
      "constraint": {
        "minInclusive": "3.2.0",
        "maxExclusive": "6.0.0"
      },
      "id": "bash",
      "probe": {
        "argv": [
          "bash",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "version ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Repository scripts on macOS and Linux",
      "source": "scripts/*.sh"
    },
    {
      "constraint": {
        "exact": "1.90.0"
      },
      "id": "cargo",
      "probe": {
        "argv": [
          "cargo",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "cargo ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Rust workspace build and package orchestration",
      "source": "rust-toolchain.toml"
    },
    {
      "constraint": {
        "exact": "0.19.0"
      },
      "id": "cargo-deny",
      "probe": {
        "argv": [
          "cargo-deny",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "cargo-deny ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Supply-chain advisory, license, source, and duplicate-version policy",
      "source": ".github/workflows/ci.yml"
    },
    {
      "constraint": {
        "exact": "0.13.1"
      },
      "id": "cargo-fuzz",
      "probe": {
        "argv": [
          "cargo-fuzz",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "cargo-fuzz ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "R7 fuzz and adversarial parser/runtime campaigns",
      "source": "ROADMAP.md#R7.1"
    },
    {
      "constraint": {
        "exact": "0.9.137"
      },
      "id": "cargo-nextest",
      "probe": {
        "argv": [
          "cargo-nextest",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "cargo-nextest ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "CI and long-session deterministic test runner",
      "source": ".github/workflows/ci.yml"
    },
    {
      "constraint": {
        "minInclusive": "16.0.0",
        "maxExclusive": "21.0.0"
      },
      "id": "clang",
      "probe": {
        "argv": [
          "clang",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "(?:Apple )?clang version ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "libFuzzer-compatible native compilation",
      "source": "ROADMAP.md#R7.1"
    },
    {
      "constraint": {
        "exact": "0.1.90"
      },
      "id": "clippy",
      "probe": {
        "argv": [
          "cargo",
          "clippy",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "clippy ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Rust lint and no-user-panic enforcement",
      "source": "rust-toolchain.toml"
    },
    {
      "constraint": {
        "minInclusive": "2.39.0",
        "maxExclusive": "3.0.0"
      },
      "id": "git",
      "probe": {
        "argv": [
          "git",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "git version ([0-9]+(?:\\.[0-9]+){0,2})"
      },
      "purpose": "Source identity, clean-state, VCS, and bootstrap provenance",
      "source": "docs/spec/ASSURANCE_ARTIFACTS_v0.1.md"
    },
    {
      "constraint": null,
      "id": "idevice-id",
      "probe": {
        "argv": [
          "idevice_id",
          "--version"
        ],
        "kind": "command-presence",
        "versionRegex": null
