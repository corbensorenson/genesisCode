    },
    {
      "constraint": {
        "exact": "0.2.108"
      },
      "id": "wasm-bindgen",
      "probe": {
        "argv": [
          "wasm-bindgen",
          "--version"
        ],
        "kind": "command-version",
        "versionRegex": "wasm-bindgen ([0-9]+(?:\\.[0-9]+){0,2})"
      },
