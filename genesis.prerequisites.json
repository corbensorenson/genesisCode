    },
    {
      "constraint": {
        "exact": "1.90.0"
      },
      "id": "rust-target-wasm32-unknown-unknown",
      "probe": {
        "kind": "rustup-target",
        "target": "wasm32-unknown-unknown"
      },
      "purpose": "Browser and Node WebAssembly library builds",
