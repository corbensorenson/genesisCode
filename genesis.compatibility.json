  "kind": "genesis/v1-compatibility-registry-v0.1",
  "version": "0.1",
  "namespace": "genesis/compat/v1",
  "releaseClaim": "reserved-not-stable",
  "stabilizationTask": "R9.1.a",
  "policy": {
    "candidateChange": "A candidate binding may change before v1 freeze only with a new candidate ID, migration record, golden vectors, and an updated source authority.",
    "dependencyRule": "A surface cannot become stable before every dependency is stable under the same v1 release candidate.",
    "reservation": "Stable IDs are permanently reserved, must never be reassigned, and do not claim compatibility until promoted to stable.",
    "retirementRule": "A stable v1 reader may be retired only by a later major compatibility policy with an offline migrator, telemetry or corpus evidence, and a published support window.",
    "stabilityRule": "Promotion is monotonic and requires every named promotion requirement; stable bytes or semantics require a new stable ID rather than reinterpretation."
  },
  "promotionRequirements": [
    {
      "id": "P-NORMATIVE-SPEC",
      "description": "A complete normative grammar or wire specification defines canonical encoding, semantics, limits, and fail-closed behavior."
    },
    {
      "id": "P-GOLDEN-CORPUS",
      "description": "Portable positive, negative, legacy, malformed, and future-version vectors are retained with deterministic identities."
    },
    {
      "id": "P-INDEPENDENT-VERIFIER",
      "description": "A separately built verifier or implementation accepts and rejects the same corpus without importing the production implementation."
    },
    {
      "id": "P-MIGRATION",
      "description": "Every accepted predecessor has a deterministic migrator, semantic-delta statement, support window, and rollback procedure."
    },
    {
      "id": "P-TIER-PARITY",
      "description": "All shipping interpreters, compilers, hosts, and selfhost stages agree on identity and observable semantics."
    },
    {
      "id": "P-SECURITY",
      "description": "Fuzzing, resource-limit, ambiguity, downgrade, and cross-profile confusion controls pass with no open release blocker."
    },
    {
      "id": "P-R9-FREEZE",
      "description": "R9.1.a records an independently verified release-candidate freeze and changes the binding state without changing the reserved stable ID."
    }
  ],
