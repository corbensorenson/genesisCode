{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesiscode.dev/schemas/evidence-verifier-negative-vectors-v0.1.json",
  "title": "GenesisCode Evidence Verifier Negative Vector Catalog v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "cases"],
  "properties": {
    "kind": {"const": "genesis/evidence-verifier-negative-vectors-v0.1"},
    "version": {"const": "0.1"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "surface", "expectedDiagnostic"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "surface": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "expectedDiagnostic": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
