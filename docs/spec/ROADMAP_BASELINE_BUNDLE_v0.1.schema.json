{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesiscode.dev/schemas/roadmap-baseline-bundle-v0.1.json",
  "title": "GenesisCode Signed E0 Roadmap Baseline Bundle v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["authority", "envelope", "evidenceClass", "kind", "signing", "statement", "version"],
  "properties": {
    "authority": {"const": "observation"},
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload", "payloadType", "signatures"],
      "properties": {
        "payload": {"type": "string", "minLength": 1},
        "payloadType": {"const": "application/vnd.genesiscode.roadmap-baseline.v0.1+json"},
        "signatures": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["keyid", "sig"],
            "properties": {
              "keyid": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
              "sig": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "evidenceClass": {"const": "E0"},
    "kind": {"const": "genesis/roadmap-baseline-bundle-v0.1"},
    "signing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "publicKeySha256", "signatureGrantsAuthority", "trust"],
      "properties": {
        "keyId": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "publicKeySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "signatureGrantsAuthority": {"const": false},
        "trust": {"const": "externally-pinned-fixture-integrity-only"}
      }
    },
    "statement": {"$ref": "ROADMAP_BASELINE_STATEMENT_v0.1.schema.json"},
    "version": {"const": "0.1"}
  }
}
