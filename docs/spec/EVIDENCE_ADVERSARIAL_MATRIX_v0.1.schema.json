{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesiscode.dev/schemas/evidence-adversarial-matrix-v0.1.json",
  "title": "GenesisCode Evidence Adversarial Matrix v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "roadmapTask", "requirements", "controls"],
  "properties": {
    "kind": {"const": "genesis/evidence-adversarial-matrix-v0.1"},
    "version": {"const": "0.1"},
    "roadmapTask": {"const": "R0.2.e"},
    "requirements": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement", "controlIds"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "statement": {"type": "string", "minLength": 1},
          "controlIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
          }
        }
      }
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "layer",
          "fixture",
          "command",
          "expectedDiagnostic",
          "authority"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "layer": {"enum": ["json-parser", "schema-profile", "artifact-path", "signature", "source-policy", "replay"]},
          "fixture": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "expectedDiagnostic": {"type": "string", "minLength": 1},
          "authority": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
