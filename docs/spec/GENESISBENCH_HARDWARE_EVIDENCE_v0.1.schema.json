{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesiscode.dev/schemas/genesisbench-hardware-evidence-v0.1.json",
  "title": "GenesisBench embedded-local resident-footprint evidence v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "measurementMethod", "metric", "modelResidentBytes", "runtimeResidentBytes", "combinedResidentBytes", "measurementTool", "startedAt", "endedAt", "contentIdentitySha256"],
  "properties": {
    "kind": {"const": "genesis/genesisbench-hardware-evidence-v0.1"},
    "version": {"const": "0.1.0"},
    "measurementMethod": {"enum": ["measured-peak-rss", "enforced-hard-ceiling"]},
    "metric": {"const": "peak-combined-model-and-runtime-resident-bytes"},
    "modelResidentBytes": {"type": "integer", "minimum": 0, "maximum": 68719476736},
    "runtimeResidentBytes": {"type": "integer", "minimum": 0, "maximum": 68719476736},
    "combinedResidentBytes": {"type": "integer", "minimum": 0, "maximum": 68719476736},
    "measurementTool": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,127}$"},
    "startedAt": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "endedAt": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "contentIdentitySha256": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
