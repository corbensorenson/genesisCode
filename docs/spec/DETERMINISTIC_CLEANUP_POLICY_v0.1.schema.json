{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesiscode.dev/schemas/deterministic-cleanup-policy-v0.1.json",
  "title": "GenesisCode Deterministic Cleanup Policy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "version", "markerFile", "quarantineRoot", "discoveryRoots", "limits", "classes", "profiles"],
  "properties": {
    "kind": {"const": "genesis/deterministic-cleanup-policy-v0.1"},
    "version": {"const": "0.1"},
    "markerFile": {"const": ".genesis-clean-root-v0.1.json"},
    "quarantineRoot": {"const": ".genesis/cleanup-quarantine"},
    "discoveryRoots": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/repoPath"}},
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxDepth", "maxEntries", "maxPlanRoots"],
      "properties": {
        "maxDepth": {"type": "integer", "minimum": 1},
        "maxEntries": {"type": "integer", "minimum": 1},
        "maxPlanRoots": {"type": "integer", "minimum": 1}
      }
    },
    "classes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "deletable", "roots"],
        "properties": {
          "id": {"enum": ["dependency-mirror", "rebuildable-output", "retained-evidence", "user-authored"]},
          "deletable": {"type": "boolean"},
          "roots": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/repoPath"}}
        }
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "deleteClasses"],
        "properties": {
          "id": {"enum": ["dev-clean", "generated-clean", "mirror-clean", "observations-clean"]},
          "deleteClasses": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": ["dependency-mirror", "rebuildable-output", "retained-evidence"]}
          }
        }
      }
    }
  },
  "$defs": {
    "repoPath": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"}
  }
}
