          (keep-refs ((core/map::get pins-info) (quote :keep-refs))))
        (let
          ((st1
             (if (core/vcs/reach::vec? keep)
               ((((core/gc/reach::pins-keep-state2 keep) (core/vec::len keep)) 0) core/gc/reach::state-empty)
               core/gc/reach::state-empty)))
          (if (core/vcs/reach::vec? keep-refs)
            ((((core/gc/reach::pins-keep-refs-state2 keep-refs) (core/vec::len keep-refs)) 0) st1)
            st1)))
      core/gc/reach::state-empty)))

(def core/gc/reach::pins-keep-state2
  (fn (keep)
    (fn (n)
      (fn (i)
        (fn (st)
          (if ((core/int::eq? i) n)
            st
            ((((core/gc/reach::pins-keep-state2 keep) n) ((core/int::add i) 1))
              (((core/gc/reach::state-add st) ((core/vec::get keep) i))
                {:hash ((core/vec::get keep) i) :kind (quote :pin)}))))))))

(def core/gc/reach::pins-keep-refs-state2
  (fn (keep-refs)
    (fn (n)
      (fn (i)
        (fn (st)
          (if ((core/int::eq? i) n)
            st
            (let ((entry ((core/vec::get keep-refs) i)))
              (let
                ((next
                   (if (core/vcs/reach::map? entry)
                     (((core/gc/reach::state-add st) ((core/map::get entry) (quote :hash)))
                       {
                         :hash ((core/map::get entry) (quote :hash))
                         :kind (quote :pin-ref)
                         :name ((core/map::get entry) (quote :name))})
                     st)))
                ((((core/gc/reach::pins-keep-refs-state2 keep-refs) n) ((core/int::add i) 1))
                  next)))))))))

(def core/gc/reach::roots-plan
  (fn (refs)
    (fn (lock-info)
      (fn (pins-info)
        (fn (include-lock)
          (fn (include-refs)
            (let
              ((ref-st
                 (if include-refs (core/gc/reach::refs-state refs) core/gc/reach::state-empty))
                (lock-st
                  (if include-lock
                    (core/gc/reach::lock-state lock-info)
                    core/gc/reach::state-empty))
                (pins-st (core/gc/reach::pins-state pins-info)))
              (let ((st1 ((core/gc/reach::state-merge ref-st) lock-st)))
                (let ((st2 ((core/gc/reach::state-merge st1) pins-st)))
                  {
                    :roots ((core/map::get st2) (quote :roots))
                    :roots-meta ((core/map::get st2) (quote :meta))})))))))))

