        (let ((tag (core/data::tag xs)))
          (if ((core/sym::eq? tag) (quote :nil))
            acc
            (if ((core/sym::eq? tag) (quote :pair))
              (let ((acc2 ((f acc) (core/list::car xs))))
                (if (core/error::is? acc2) acc2 (((core/list::foldl2 (core/list::cdr xs)) acc2) f)))
              (core/list::type-error "core/list::foldl expects a proper list"))))))))

