(def core/editor/action::task
  (fn (task-kind)
    (fn (payload) (fn (priority) (((core/editor/task::spawn task-kind) payload) priority)))))

(def core/editor/action::format-source
  (fn (src)
    (let ((formatted (core/coreform::fmt-module src)))
      (if (core/error::is? formatted)
        {
          :error (core/error::payload formatted)
          :formatted nil
          :hash nil
          :kind (quote :editor/coreform-format-result)
          :ok false}
        {
          :error nil
          :formatted formatted
          :hash (core/coreform::hash-module-src formatted)
          :kind (quote :editor/coreform-format-result)
          :ok true}))))

(def core/editor/action::format-file-task
  (fn (path) (((core/editor/action::task (quote editor/task::fmt-coreform)) {:path path}) 50)))

(def core/editor/action::parse-source (fn (src) (core/editor/ast::parse-module-index src)))

(def core/editor/action::parse-file-task
