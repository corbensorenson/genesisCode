      (
        ((core/editor/action::task (quote editor/task::lint-module))
          {:changed-syms changed-syms :path path})
        50))))

(def core/editor/action::lint-module-task-from-sources
  (fn (path)
    (fn (before-src)
      (fn (after-src)
        (let
          ((before-index (core/editor/ast::parse-module-index before-src))
            (after-index (core/editor/ast::parse-module-index after-src)))
          (
            ((core/editor/action::task (quote editor/task::lint-module))
              {
                :changed-syms ((core/editor/ast::changed-syms before-index) after-index)
                :path path})
            50))))))

