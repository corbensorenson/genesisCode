  (fn (xs)
    (fn (acc)
      (let ((tag (core/data::tag xs)))
        (if ((core/sym::eq? tag) (quote :nil))
          acc
          (if ((core/sym::eq? tag) (quote :pair))
            ((core/list::reverse2 (core/list::cdr xs)) ((core/list::cons (core/list::car xs)) acc))
            (core/list::type-error "core/list::reverse expects a proper list")))))))

