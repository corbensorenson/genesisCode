            :frozen frozen
            :lock lock
            :strict true})
        (fn (resp) (core/effect::pure resp))))))

(def core/pm::verify
  (fn (lock)
    (((core/effect::perform (quote core/pkg-low::verify)) {:lock lock :strict true})
      (fn (resp) (core/effect::pure resp)))))

(def core/pm::publish
  (fn (remote)
    (fn (refname)
      (fn (policy)
        (fn (expected-old)
          (fn (depth)
            (fn (commit)
              (if ((core/eq? policy) nil)
                (core/effect::pure
                  ((core/error::make2 "core/pm/missing-policy")
                    "core/pm::publish requires a non-nil policy hash"))
                (
                  ((core/effect::perform (quote core/pkg-low::publish))
                    {
                      :commit commit
                      :depth depth
                      :expected-old expected-old
                      :policy policy
                      :ref refname
                      :remote remote})
                  (fn (resp) (core/effect::pure resp)))))))))))

