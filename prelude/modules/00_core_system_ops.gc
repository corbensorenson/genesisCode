                  ((core/effect::perform (quote core/gc-low::run))
                    {
                      :depth depth
                      :include-lock include-lock
                      :include-refs include-refs
                      :lock lock
                      :pins pins
                      :quarantine quarantine
                      :quarantine-dir quarantine-dir})
                  (fn (resp) (core/effect::pure resp)))))))))))

