(def core/contract::call
  (fn (c) (fn (op) (fn (payload) ((core/contract::dispatch c) ((core/msg::make op) payload))))))

(def core/store::put
  (fn (artifact)
    (((core/effect::perform (quote core/store::put)) {:artifact artifact})
      (fn (resp) (core/effect::pure resp)))))

(def core/store::get
  (fn (hash)
    (((core/effect::perform (quote core/store::get)) {:hash hash})
