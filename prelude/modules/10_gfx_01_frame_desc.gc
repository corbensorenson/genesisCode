          :op (quote :set-index-buffer)
          :buffer buffer
          :offset-bytes offset-bytes
          :index-format index-format}))))

(def core/gfx/frame::cmd-set-bind-group
  (fn (index) (fn (bind-group) {:op (quote :set-bind-group) :index index :bind-group bind-group})))

(def core/gfx/frame::cmd-set-push-constants
  (fn (stage)
