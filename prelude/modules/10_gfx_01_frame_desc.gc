(def core/gfx/frame::render-pass-empty
  (fn (label) ((((core/gfx/frame::render-pass label) []) nil) [])))

(def core/gfx/frame::compute-pass-empty (fn (label) ((core/gfx/frame::compute-pass label) [])))

(def core/gfx/frame::render-pass-add-command
  (fn (pass)
    (fn (cmd)
      (((core/map::put pass) (quote :commands))
        ((core/vec::push ((core/map::get pass) (quote :commands))) cmd)))))

(def core/gfx/frame::compute-pass-add-command
  (fn (pass)
    (fn (cmd)
      (((core/map::put pass) (quote :commands))
        ((core/vec::push ((core/map::get pass) (quote :commands))) cmd)))))

(def core/gfx/frame::render-pass-add-color-attachment
  (fn (pass)
    (fn (attachment)
      (((core/map::put pass) (quote :color-attachments))
        ((core/vec::push ((core/map::get pass) (quote :color-attachments))) attachment)))))

(def core/gfx/frame::color-attachment
  (fn (view)
    (fn (clear)
      (fn (load-op)
        (fn (store-op)
          {
            :type (quote :gfx/color-attachment)
            :view view
            :clear clear
            :load-op load-op
            :store-op store-op})))))

(def core/gfx/frame::depth-attachment
  (fn (view)
    (fn (clear-depth)
      (fn (clear-stencil)
        (fn (load-op)
          (fn (store-op)
            {
              :type (quote :gfx/depth-attachment)
              :view view
              :clear-depth clear-depth
              :clear-stencil clear-stencil
              :load-op load-op
              :store-op store-op}))))))

(def core/gfx/frame::cmd-set-pipeline (fn (pipeline) {:op (quote :set-pipeline) :pipeline pipeline}))

(def core/gfx/frame::cmd-set-vertex-buffer
  (fn (slot)
    (fn (buffer)
      (fn (offset-bytes)
        {
          :op (quote :set-vertex-buffer)
          :slot slot
          :buffer buffer
          :offset-bytes offset-bytes}))))

