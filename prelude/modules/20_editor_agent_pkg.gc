(def core/editor/agent::session-empty
  (fn (agent-id)
    {
      :agent agent-id
      :events []
      :evidence []
      :kind (quote :editor/agent-session)
      :patches []}))

(def core/editor/agent::session-add-event
  (fn (session)
    (fn (event)
      (prim map/put
        session
        (quote :events)
        ((core/vec::push (core/editor/lint::vec-or-empty ((core/map::get session) (quote :events))))
          event)))))

(def core/editor/agent::session-add-patch
  (fn (session)
    (fn (patch-h)
      (prim map/put
        session
        (quote :patches)
        ((core/vec::push (core/editor/lint::vec-or-empty ((core/map::get session) (quote :patches))))
          patch-h)))))

(def core/editor/agent::session-add-evidence
  (fn (session)
    (fn (evidence-h)
      (prim map/put
        session
        (quote :evidence)
        ((core/vec::push (core/editor/lint::vec-or-empty ((core/map::get session) (quote :evidence))))
          evidence-h)))))

(def core/editor/agent::session-hash (fn (session) (core/coreform::hash-term session)))

(def core/editor/agent::session-log-artifact
  (fn (session)
    {
      :kind (quote genesis/editor-agent-session-v0.2)
      :session session
      :session-h (core/editor/agent::session-hash session)
      :v 1}))

(def core/editor/agent::store-session-log
  (fn (session) (core/store::put (core/editor/agent::session-log-artifact session))))

(def core/editor/agent::bool-or-false
  (fn (x) (if ((core/sym::eq? (core/data::tag x)) (quote :bool)) x false)))

(def core/editor/agent::verify-ok?
  (fn (verify-resp)
    (if (core/editor/lint::map? verify-resp)
      (core/editor/agent::bool-or-false ((core/map::get verify-resp) (quote :ok)))
      false)))

(def core/editor/agent::acceptance-report
  (fn (apply-resp)
    (fn (verify-resp)
      {
        :accepted
          (if (core/editor/agent::verify-ok? verify-resp)
            (core/editor/agent::bool-or-false ((core/map::get apply-resp) (quote :ok)))
            false)
        :apply apply-resp
        :kind (quote :editor/agent-acceptance)
        :verify verify-resp})))

(def core/editor/agent::present?
  (fn (x) (if ((core/sym::eq? (core/data::tag x)) (quote :nil)) false true)))

(def core/editor/agent::int-or-zero
  (fn (x) (if ((core/sym::eq? (core/data::tag x)) (quote :int)) x 0)))

(def core/editor/agent::normalize-side
  (fn (x)
    (let
      ((s
         (if (core/editor/lint::sym? x)
           (core/sym::to-str x)
           (if (core/editor/lint::str? x) x ""))))
      (if (prim core/eq? s "left")
        (quote :left)
        (if (prim core/eq? s ":left")
          (quote :left)
          (if (prim core/eq? s "base")
            (quote :base)
            (if (prim core/eq? s ":base") (quote :base) (quote :right))))))))

(def core/editor/agent::conflict-op-key
  (fn (entry)
    (if (core/editor/lint::map? entry)
      (let ((op ((core/map::get entry) (quote :op))))
        (if (core/editor/lint::sym? op)
          op
          (if (core/editor/lint::str? op) (core/sym::from-str op) nil)))
      nil)))

(def core/editor/agent::choose-side
  (fn (entry)
    (fn (prefer)
      (if (core/editor/lint::map? entry)
        (let
          ((base ((core/map::get entry) (quote :base)))
            (left ((core/map::get entry) (quote :left)))
            (right ((core/map::get entry) (quote :right))))
          (if ((core/sym::eq? prefer) (quote :left))
            (if (core/editor/agent::present? left)
              (quote :left)
              (if (core/editor/agent::present? right)
                (quote :right)
                (if (core/editor/agent::present? base) (quote :base) nil)))
            (if ((core/sym::eq? prefer) (quote :right))
              (if (core/editor/agent::present? right)
                (quote :right)
                (if (core/editor/agent::present? left)
                  (quote :left)
                  (if (core/editor/agent::present? base) (quote :base) nil)))
              (if (core/editor/agent::present? base)
                (quote :base)
                (if (core/editor/agent::present? right)
                  (quote :right)
                  (if (core/editor/agent::present? left) (quote :left) nil))))))
        nil))))

(def core/editor/agent::conflict-plan-loop
  (fn (conflicts)
    (fn (prefer)
      (fn (i)
        (fn (resolutions)
          (fn (ops)
            (if ((core/int::eq? i) (core/vec::len conflicts))
              {:ops ops :resolutions resolutions}
              (let
                ((entry ((core/vec::get conflicts) i))
                  (next
                    (((core/editor/agent::conflict-plan-loop conflicts) prefer)
                      ((core/int::add i) 1))))
                (let
                  ((opk (core/editor/agent::conflict-op-key entry))
                    (side ((core/editor/agent::choose-side entry) prefer)))
                  (if (core/editor/lint::sym? opk)
                    (if (core/editor/lint::sym? side)
                      ((next (prim map/put resolutions opk side))
                        ((core/vec::push ops) (core/sym::to-str opk)))
                      ((next resolutions) ops))
                    ((next resolutions) ops)))))))))))

(def core/editor/agent::conflict-resolution-plan
  (fn (conflict-h)
    (fn (conflict-panel)
      (fn (prefer)
        (let
          ((pref (core/editor/agent::normalize-side prefer))
            (conflicts
              (if (core/editor/lint::map? conflict-panel)
                (core/editor/vcs::vec-or-empty ((core/map::get conflict-panel) (quote :conflicts)))
                [])))
          (let ((planned (((((core/editor/agent::conflict-plan-loop conflicts) pref) 0) {}) [])))
            {
              :conflict conflict-h
              :count (core/vec::len ((core/map::get planned) (quote :ops)))
              :kind (quote :editor/agent-conflict-resolution-plan)
              :ok true
              :ops ((core/map::get planned) (quote :ops))
              :resolutions ((core/map::get planned) (quote :resolutions))
              :strategy pref}))))))

(def core/editor/agent::semantic-patch-plan
  (fn (base)
    (fn (to)
      (fn (before-src)
        (fn (after-src)
          (let
            ((before-index (core/editor/ast::parse-module-index before-src))
              (after-index (core/editor/ast::parse-module-index after-src)))
            (let
              ((before-ok (core/editor/ast::module-index-ok? before-index))
                (after-ok (core/editor/ast::module-index-ok? after-index)))
              (let
                ((changed
                   (if before-ok
                     (if after-ok ((core/editor/ast::changed-syms before-index) after-index) [(quote ::meta)])
                     [(quote ::meta)])))
                {
                  :after-error ((core/map::get after-index) (quote :error))
                  :after-h (core/coreform::hash-module-src after-src)
                  :after-ok after-ok
                  :base base
                  :before-error ((core/map::get before-index) (quote :error))
                  :before-h (core/coreform::hash-module-src before-src)
                  :before-ok before-ok
                  :changed-count (core/vec::len changed)
                  :changed-syms changed
                  :kind (quote :editor/agent-semantic-patch-plan)
                  :meta-changed ((core/editor/ast::contains-sym? changed) (quote ::meta))
                  :ok (if before-ok after-ok false)
                  :to to}))))))))

(def core/editor/agent::repair-plan
  (fn (acceptance)
    (fn (lint-panel)
      (let
        ((accepted (core/editor/agent::bool-or-false ((core/map::get acceptance) (quote :accepted))))
          (verify-ok (core/editor/agent::verify-ok? ((core/map::get acceptance) (quote :verify))))
          (error-count (core/editor/agent::int-or-zero ((core/map::get lint-panel) (quote :error-count))))
          (warn-count (core/editor/agent::int-or-zero ((core/map::get lint-panel) (quote :warn-count))))
          (autofixes (core/editor/lint::vec-or-empty ((core/map::get lint-panel) (quote :autofixes)))))
        (let
          ((steps0 [])
            (steps1
              (if ((core/int::lt? 0) (core/vec::len autofixes))
                ((core/vec::push steps0) {:op (quote :apply-autofixes) :payload {:patches autofixes}})
                steps0))
            (steps2
              (if ((core/int::lt? 0) error-count)
                ((core/vec::push steps1)
                  {:op (quote :run-lint) :payload {:changed-syms [(quote ::meta)] :strict true}})
                steps1))
            (steps3
              (if verify-ok
                steps2
                ((core/vec::push steps2) {:op (quote :run-obligation-verify) :payload {:strict true}})))
            (steps4
              (if accepted steps3 ((core/vec::push steps3) {:op (quote :run-tests) :payload {:strict true}}))))
          {
            :accepted accepted
            :autofix-count (core/vec::len autofixes)
            :error-count error-count
            :kind (quote :editor/agent-repair-plan)
            :ok true
            :steps (if accepted ((core/vec::push steps4) {:op (quote :publish-candidate) :payload {}}) steps4)
            :verify-ok verify-ok
            :warn-count warn-count})))))

(def core/editor/action::agent-propose-patch
  (fn (base)
    (fn (to)
      ((core/effect::map ((((core/vcs::diff base) to) nil) true))
        core/editor/vcs::diff-panel-from-response))))

(def core/editor/action::agent-plan-and-propose-patch
  (fn (base)
    (fn (to)
      (fn (before-src)
        (fn (after-src)
          (let ((plan ((((core/editor/agent::semantic-patch-plan base) to) before-src) after-src)))
            ((core/effect::map ((((core/vcs::diff base) to) nil) true))
              (fn (diff-panel)
                (prim map/put
                  (prim map/put plan (quote :diff) diff-panel)
                  (quote :patch)
                  ((core/map::get diff-panel) (quote :patch)))))))))))

(def core/editor/action::agent-apply-patch-with-obligations
  (fn (base)
    (fn (patch)
      (fn (lock)
        (fn (strict)
          ((core/effect::bind ((((core/vcs::apply base) patch) nil) true))
            (fn (apply-resp)
              (if (core/editor/agent::bool-or-false ((core/map::get apply-resp) (quote :ok)))
                ((core/effect::bind ((core/pkg::verify lock) strict))
                  (fn (verify-resp)
                    (core/effect::pure
                      ((core/editor/agent::acceptance-report apply-resp) verify-resp))))
                (core/effect::pure ((core/editor/agent::acceptance-report apply-resp) nil))))))))))

(def core/editor/action::agent-conflict-resolution-plan
  (fn (conflict-h)
    (fn (prefer)
      ((core/effect::map (core/editor/action::vcs-conflict-panel conflict-h))
        (fn (panel) (((core/editor/agent::conflict-resolution-plan conflict-h) panel) prefer))))))

(def core/editor/action::agent-repair-plan-from-acceptance
  (fn (acceptance)
    ((core/effect::bind (core/editor/action::lint-panel-from-acceptance acceptance))
      (fn (lint-panel) (core/effect::pure ((core/editor/agent::repair-plan acceptance) lint-panel))))))

(def core/editor/pkg::field
  (fn (resp) (fn (k) (if (core/editor/lint::map? resp) ((core/map::get resp) k) nil))))

(def core/editor/pkg::vec-or-empty (fn (x) (if (core/editor/lint::vec? x) x [])))

(def core/editor/pkg::list-panel-from-response
  (fn (resp)
    (let
      ((f (core/editor/pkg::field resp))
        (reqs (core/editor/pkg::vec-or-empty (f (quote :requirements))))
        (locked (core/editor/pkg::vec-or-empty (f (quote :locked)))))
      {
        :kind (quote :editor/pkg-list-panel)
        :lock (f (quote :lock))
        :locked locked
        :locked-count (core/vec::len locked)
        :ok (f (quote :ok))
        :requirements reqs
        :requirements-count (core/vec::len reqs)})))

(def core/editor/pkg::info-panel-from-response
  (fn (resp)
    (let ((f (core/editor/pkg::field resp)))
      {
        :kind (quote :editor/pkg-info-panel)
        :locked (f (quote :locked))
        :name (f (quote :name))
        :ok (f (quote :ok))
        :requirement (f (quote :requirement))})))

(def core/editor/pkg::status-panel-from-response
  (fn (kind)
    (fn (resp)
      (let
        ((f (core/editor/pkg::field resp))
          (missing (core/editor/pkg::vec-or-empty (f (quote :missing)))))
        {
          :checked (f (quote :checked))
          :kind kind
          :lock (f (quote :lock))
          :lock-h (f (quote :lock-h))
          :locked-count (f (quote :locked-count))
          :missing missing
          :missing-count (core/vec::len missing)
          :ok (f (quote :ok))
          :present (f (quote :present))
          :refs-updated (f (quote :refs-updated))
          :remote (f (quote :remote))
          :snapshot (f (quote :snapshot))
          :total (f (quote :total))
          :updated (f (quote :updated))
          :uploaded (f (quote :uploaded))}))))

(def core/editor/action::pkg-list-panel
  (fn (lock) ((core/effect::map (core/pkg::list lock)) core/editor/pkg::list-panel-from-response)))

(def core/editor/action::pkg-info-panel
  (fn (lock)
    (fn (name)
      ((core/effect::map ((core/pkg::info lock) name)) core/editor/pkg::info-panel-from-response))))

(def core/editor/action::pkg-lock-panel
  (fn (lock)
    ((core/effect::map (core/pkg::lock lock))
      (core/editor/pkg::status-panel-from-response (quote :editor/pkg-lock-panel)))))

(def core/editor/action::pkg-update-panel
  (fn (lock)
    ((core/effect::map (core/pkg::update lock))
      (core/editor/pkg::status-panel-from-response (quote :editor/pkg-update-panel)))))

(def core/editor/action::pkg-install-panel
  (fn (lock)
    (fn (frozen)
      (fn (strict)
        ((core/effect::map (((core/pkg::install lock) frozen) strict))
          (core/editor/pkg::status-panel-from-response (quote :editor/pkg-install-panel)))))))

(def core/editor/action::pkg-verify-panel
  (fn (lock)
    (fn (strict)
      ((core/effect::map ((core/pkg::verify lock) strict))
        (core/editor/pkg::status-panel-from-response (quote :editor/pkg-verify-panel))))))

(def core/editor/action::pkg-snapshot-panel
  (fn (pkg-path)
    ((core/effect::map (core/pkg::snapshot pkg-path))
      (core/editor/pkg::status-panel-from-response (quote :editor/pkg-snapshot-panel)))))

(def core/editor/action::gpk-export-panel
  (fn (root)
    (fn (out)
      (fn (mode)
        (fn (depth)
          (fn (refs)
            ((core/effect::map (((((core/gpk::export root) out) mode) depth) refs))
              (core/editor/pkg::status-panel-from-response (quote :editor/gpk-export-panel)))))))))

(def core/editor/action::gpk-import-panel
  (fn (in)
    ((core/effect::map (core/gpk::import in))
      (core/editor/pkg::status-panel-from-response (quote :editor/gpk-import-panel)))))

(def core/editor/action::sync-pull-panel
  (fn (remote)
    (fn (refs)
      (fn (roots)
        (fn (depth)
          (fn (force)
            (fn (set-refs)
              ((core/effect::map ((((((core/sync::pull remote) refs) roots) depth) force) set-refs))
                (core/editor/pkg::status-panel-from-response (quote :editor/sync-pull-panel))))))))))

(def core/editor/action::sync-push-panel
  (fn (remote)
    (fn (refs)
      (fn (roots)
        (fn (depth)
          ((core/effect::map ((((core/sync::push remote) refs) roots) depth))
            (core/editor/pkg::status-panel-from-response (quote :editor/sync-push-panel))))))))
