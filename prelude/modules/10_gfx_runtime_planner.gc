(def core/gfx/runtime::2d-batches-loop
  (fn (draws)
    (fn (i)
      (fn (n)
        (fn (current-key)
          (fn (current-count)
            (fn (out)
              (if ((core/int::lt? i) n)
                (let ((draw ((core/vec::get draws) i))
                      (key (core/gfx/runtime::2d-draw-batch-key draw))
                      (i2 ((core/int::add i) 1)))
                  (if ((core/eq? key) current-key)
                    ((((((core/gfx/runtime::2d-batches-loop draws) i2) n) current-key)
                      ((core/int::add current-count) 1))
                      out)
                    (let ((out2
                            (if ((core/int::lt? 0) current-count)
                              ((core/vec::push out) ((core/gfx/runtime::2d-batch current-key) current-count))
                              out)))
                      ((((((core/gfx/runtime::2d-batches-loop draws) i2) n) key) 1) out2))))
                (if ((core/int::lt? 0) current-count)
                  ((core/vec::push out) ((core/gfx/runtime::2d-batch current-key) current-count))
                  out)))))))))

