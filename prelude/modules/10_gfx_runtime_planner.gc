(def core/gfx/runtime::append-shadow-passes-loop
  (fn (graph)
    (fn (scene)
      (fn (shadow-label-prefix)
        (fn (shadow-pipeline-id)
          (fn (shadow-depth-prefix)
            (fn (i)
              (fn (n)
                (if ((core/int::lt? i) n)
                  (let ((i2 ((core/int::add i) 1))
                        (idx-str (core/int::to-str i))
                        (label ((core/str::concat shadow-label-prefix) idx-str))
                        (depth-view ((core/str::concat shadow-depth-prefix) idx-str))
                        (depth-att
                          (((((core/gfx/frame::depth-attachment depth-view) 1000000) 0) "clear")
                            "store"))
                        (shadow-pass
                          (((((core/gfx/runtime::plan-render-pass-3d scene) label) shadow-pipeline-id) [])
                            depth-att))
                        (graph2 ((core/gfx/frame::add-render-pass graph) shadow-pass)))
                    (((((((core/gfx/runtime::append-shadow-passes-loop graph2) scene) shadow-label-prefix)
                      shadow-pipeline-id)
                      shadow-depth-prefix)
                      i2)
                      n))
                  graph)))))))))

(def core/gfx/runtime::plan-frame-3d-pbr
  (fn (scene)
    (fn (main-label)
      (fn (main-pipeline-id)
        (fn (main-color-attachments)
          (fn (main-depth-attachment)
            (fn (shadow-label-prefix)
              (fn (shadow-pipeline-id)
                (fn (shadow-depth-prefix)
                  (let ((camera (core/gfx/runtime::first-camera scene))
                        (light-count (core/gfx/runtime::count-lights scene))
                        (shadow-count (core/gfx/runtime::count-shadow-lights scene))
                        (main-pass
                          (((((core/gfx/runtime::plan-render-pass-3d scene) main-label) main-pipeline-id)
                            main-color-attachments)
                            main-depth-attachment))
                        (graph-main ((core/gfx/frame::add-render-pass core/gfx/frame::empty) main-pass))
                        (graph-shadows
                          (((((((core/gfx/runtime::append-shadow-passes-loop graph-main) scene)
                            shadow-label-prefix)
                            shadow-pipeline-id)
                            shadow-depth-prefix)
                            0)
                            shadow-count))
                        (meta
                          {
                            :camera camera
                            :light-count light-count
                            :shadow-light-count shadow-count}))
                    (((core/map::put graph-shadows) (quote :meta)) meta)))))))))))

