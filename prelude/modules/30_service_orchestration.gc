(def core/obligation::plan-contains-str?
  (fn (xs)
    (fn (needle)
      ((((core/obligation::plan-contains-str-loop xs) needle) (core/vec::len xs)) 0))))

(def core/obligation::plan-contains-str-loop
  (fn (xs)
    (fn (needle)
      (fn (n)
        (fn (i)
          (if ((core/int::eq? i) n)
            false
            (let ((x ((core/vec::get xs) i)))
              (if (if (core/obligation::str? x) (core/obligation::str? needle) false)
                (if ((core/eq? x) needle)
                  true
                  ((((core/obligation::plan-contains-str-loop xs) needle) n)
                    ((core/int::add i) 1)))
                ((((core/obligation::plan-contains-str-loop xs) needle) n)
                  ((core/int::add i) 1))))))))))

(def core/obligation::plan-push-unique-str
  (fn (xs)
    (fn (v)
      (if (if (core/obligation::str? v) ((core/obligation::plan-contains-str? xs) v) false)
        xs
        (if (core/obligation::str? v) ((core/vec::push xs) v) xs)))))

(def core/obligation::known-obligation?
  (fn (name)
    (if ((core/eq? name) "core/obligation::unit-tests")
      true
      (if ((core/eq? name) "core/obligation::budgets")
        true
        (if ((core/eq? name) "core/obligation::property-tests")
          true
          (if ((core/eq? name) "core/obligation::coverage")
            true
            (if ((core/eq? name) "core/obligation::coverage-decision")
              true
              (if ((core/eq? name) "core/obligation::coverage-mcdc")
                true
                (if ((core/eq? name) "core/obligation::determinism")
                  true
                  (if ((core/eq? name) "core/obligation::capabilities-declared")
                    true
                    (if ((core/eq? name) "core/obligation::replayable-tests")
                      true
                      (if ((core/eq? name) "core/obligation::concurrency-replay")
                        true
                        (if ((core/eq? name) "core/obligation::typecheck")
                          true
                          (if ((core/eq? name) "core/obligation::typecheck-strict")
                            true
                            (if ((core/eq? name) "core/obligation::stage1-validation")
                              true
                              (if ((core/eq? name) "core/obligation::translation-validation")
                                true
                                (if ((core/eq? name) "core/obligation::gfx-golden-images")
                                  true
                                  (if ((core/eq? name) "core/obligation::gfx-frame-budgets")
                                    true
                                    (if ((core/eq? name) "core/obligation::gfx-api-stability")
                                      true
                                      (if ((core/eq? name) "core/obligation::lint")
                                        true
                                        (if ((core/eq? name) "core/obligation::ai-style")
                                          true
                                          false)))))))))))))))))))))

(def core/obligation::plan-loop
  (fn (obligations)
    (fn (n)
      (fn (i)
        (fn (run)
          (fn (rejected)
            (if ((core/int::eq? i) n)
              {:rejected rejected :run run}
              (let ((next ((((core/obligation::plan-loop obligations) n) ((core/int::add i) 1)))))
                (let ((ob ((core/vec::get obligations) i)))
                  (if (core/obligation::str? ob)
                    (if (core/obligation::known-obligation? ob)
                      ((next ((core/obligation::plan-push-unique-str run) ob)) rejected)
                      (next run ((core/obligation::plan-push-unique-str rejected) ob)))
                    (next run ((core/vec::push rejected) (core/sym::to-str (core/data::tag ob))))))))))))))

(def core/obligation::plan
  (fn (obligations0)
    (let ((obligations (core/obligation::vec-or-empty obligations0)))
      (let ((state (((((core/obligation::plan-loop obligations) (core/vec::len obligations)) 0) []) [])))
        {
          :kind "genesis/obligation-plan-v0.2"
          :rejected (core/obligation::vec-or-empty ((core/map::get state) (quote :rejected)))
          :run (core/obligation::vec-or-empty ((core/map::get state) (quote :run)))}))))
