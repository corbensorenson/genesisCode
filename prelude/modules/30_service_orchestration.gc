(def core/obligation::vec-or-empty (fn (x) (if (core/obligation::vec? x) x [])))

(def core/obligation::unit-test-case-ok
  (fn (t)
    (if (core/obligation::map? t)
      (let ((v ((core/map::get t) (quote :ok))))
        (if (core/obligation::bool? v) v false))
      false)))

(def core/obligation::unit-tests-ok
  (fn (tests) ((((core/obligation::unit-tests-ok-loop tests) (core/vec::len tests)) 0) true)))

(def core/obligation::unit-tests-ok-loop
  (fn (tests)
    (fn (n)
      (fn (i)
        (fn (ok)
          (if ok
            (if ((core/int::eq? i) n)
              true
              ((((core/obligation::unit-tests-ok-loop tests) n) ((core/int::add i) 1))
                (core/obligation::unit-test-case-ok ((core/vec::get tests) i))))
            false))))))

(def core/obligation::unit-tests-report
  (fn (package)
