          :obligations (core/editor/vcs::vec-or-empty (f (quote :obligations)))
          :parents (core/editor/vcs::vec-or-empty (f (quote :parents)))
          :patch (f (quote :patch))
          :result (f (quote :result))
          :target (f (quote :target))}))))

(def core/editor/vcs::evidence-panel-from-artifact
  (fn (evidence-h)
    (fn (artifact)
      (let
        ((f (core/editor/vcs::field artifact))
          (inputs (core/editor/vcs::vec-or-empty (f (quote :inputs))))
          (outputs (core/editor/vcs::vec-or-empty (f (quote :outputs)))))
        {
          :data (f (quote :data))
          :hash evidence-h
          :input-count (core/vec::len inputs)
          :inputs inputs
          :kind (quote :editor/vcs-evidence-panel)
          :output-count (core/vec::len outputs)
          :outputs outputs
          :produced-by (f (quote :produced-by))
          :vcs-kind (f (quote :kind))}))))

(def core/editor/vcs::evidence-list-panel-from-commit-panel
  (fn (commit-panel)
    (let
      ((evidence (core/editor/vcs::vec-or-empty ((core/map::get commit-panel) (quote :evidence)))))
      {
        :commit ((core/map::get commit-panel) (quote :hash))
        :count (core/vec::len evidence)
        :evidence evidence
        :kind (quote :editor/vcs-evidence-list-panel)})))

(def core/editor/action::vcs-refs-panel
  (fn (prefix)
    ((core/effect::map (core/refs::list prefix)) core/editor/vcs::refs-panel-from-response)))

(def core/editor/action::vcs-log-panel
  (fn (root)
    (fn (max)
      ((core/effect::map ((core/vcs::log root) max)) core/editor/vcs::log-panel-from-response))))

(def core/editor/action::vcs-commit-panel
  (fn (commit-h)
    ((core/effect::bind (core/store::get commit-h))
      (fn (resp)
        (let ((artifact ((core/map::get resp) (quote :artifact))))
          (core/effect::pure ((core/editor/vcs::commit-panel-from-artifact commit-h) artifact)))))))

(def core/editor/action::vcs-evidence-panel
  (fn (evidence-h)
    ((core/effect::bind (core/store::get evidence-h))
      (fn (resp)
        (let ((artifact ((core/map::get resp) (quote :artifact))))
          (core/effect::pure ((core/editor/vcs::evidence-panel-from-artifact evidence-h) artifact)))))))

(def core/editor/action::vcs-evidence-list-panel
  (fn (commit-h)
    ((core/effect::bind (core/editor/action::vcs-commit-panel commit-h))
      (fn (commit-panel)
        (core/effect::pure (core/editor/vcs::evidence-list-panel-from-commit-panel commit-panel))))))

(def core/editor/action::lint-panel-from-acceptance
  (fn (acceptance) (core/editor/lint::load-panel-from-acceptance acceptance)))

(def core/editor/vcs::field
  (fn (resp) (fn (k) (if (core/editor/lint::map? resp) ((core/map::get resp) k) nil))))

(def core/editor/vcs::diff-panel-from-response
  (fn (resp)
    (let ((f (core/editor/vcs::field resp)))
      {
        :kind (quote :editor/vcs-diff-panel)
        :ok (f (quote :ok))
        :patch (f (quote :patch))
        :values (core/editor/vcs::vec-or-empty (f (quote :values)))})))

(def core/editor/vcs::apply-panel-from-response
  (fn (resp)
    (let ((f (core/editor/vcs::field resp)))
      {
        :kind (quote :editor/vcs-apply-panel)
        :ok (f (quote :ok))
        :snapshot (f (quote :snapshot))})))

(def core/editor/vcs::merge-panel-from-response
  (fn (resp)
    (let ((f (core/editor/vcs::field resp)))
      {
        :conflict (f (quote :conflict))
        :kind (quote :editor/vcs-merge-panel)
        :ok (f (quote :ok))
        :snapshot (f (quote :snapshot))})))

(def core/editor/vcs::resolve-panel-from-response
  (fn (resp)
    (let ((f (core/editor/vcs::field resp)))
      {
        :conflict (f (quote :conflict))
        :kind (quote :editor/vcs-resolve-panel)
        :ok (f (quote :ok))
        :patch (f (quote :patch))
        :snapshot (f (quote :snapshot))
        :values (core/editor/vcs::vec-or-empty (f (quote :values)))})))

(def core/editor/vcs::conflict-panel-from-artifact
  (fn (conflict)
    (let
      ((f (core/editor/vcs::field conflict))
        (items (core/editor/vcs::vec-or-empty (f (quote :conflicts)))))
      {
        :base (f (quote :base))
        :conflicts items
        :count (core/vec::len items)
        :kind (quote :editor/vcs-conflict-panel)
        :left (f (quote :left))
        :ok true
        :right (f (quote :right))
        :vcs-kind (f (quote :kind))})))

(def core/editor/action::vcs-diff-panel
  (fn (base)
    (fn (to)
      ((core/effect::map ((((core/vcs::diff base) to) nil) true))
        core/editor/vcs::diff-panel-from-response))))

(def core/editor/action::vcs-apply-panel
  (fn (base)
    (fn (patch)
      ((core/effect::map ((((core/vcs::apply base) patch) nil) true))
        core/editor/vcs::apply-panel-from-response))))

(def core/editor/action::vcs-merge3-panel
  (fn (base)
    (fn (left)
      (fn (right)
        ((core/effect::map (((((core/vcs::merge3 base) left) right) nil) true))
          core/editor/vcs::merge-panel-from-response)))))

(def core/editor/action::vcs-resolve-conflict-panel
  (fn (conflict)
    ((core/effect::map (((core/vcs::resolve-conflict conflict) nil) true))
      core/editor/vcs::resolve-panel-from-response)))

(def core/editor/action::vcs-resolve-conflict-with-panel
  (fn (conflict)
    (fn (strategy)
      (fn (resolutions)
        (
          (core/effect::map
            (
              ((core/effect::perform (quote core/vcs::resolve-conflict))
                {
                  :conflict conflict
                  :out nil
                  :resolutions resolutions
                  :store true
                  :strategy strategy})
              (fn (resp) (core/effect::pure resp))))
          core/editor/vcs::resolve-panel-from-response)))))

(def core/editor/action::vcs-conflict-panel
  (fn (conflict-h)
    ((core/effect::bind (core/store::get conflict-h))
      (fn (resp)
        (let ((artifact ((core/map::get resp) (quote :artifact))))
          (core/effect::pure (core/editor/vcs::conflict-panel-from-artifact artifact)))))))

(def core/editor/action::task
  (fn (task-kind)
    (fn (payload) (fn (priority) (((core/editor/task::spawn task-kind) payload) priority)))))

(def core/editor/action::format-source
  (fn (src)
    (let ((formatted (core/coreform::fmt-module src)))
      (if (core/error::is? formatted)
        {
          :error (core/error::payload formatted)
          :formatted nil
          :hash nil
          :kind (quote :editor/coreform-format-result)
          :ok false}
        {
          :error nil
          :formatted formatted
          :hash (core/coreform::hash-module-src formatted)
          :kind (quote :editor/coreform-format-result)
          :ok true}))))

(def core/editor/action::format-file-task
  (fn (path) (((core/editor/action::task (quote editor/task::fmt-coreform)) {:path path}) 50)))

(def core/editor/action::lint-module-task
  (fn (path)
    (fn (changed-syms)
      (
        ((core/editor/action::task (quote editor/task::lint-module))
          {:changed-syms changed-syms :path path})
        50))))

(def core/editor/action::typecheck-pkg-task
  (fn (pkg) (((core/editor/action::task (quote editor/task::typecheck-pkg)) {:pkg pkg}) 50)))

(def core/editor/action::optimize-module-task
  (fn (path)
    (fn (out)
      (((core/editor/action::task (quote editor/task::optimize-module)) {:out out :path path}) 50))))

(def core/editor/action::test-pkg-task
  (fn (pkg)
    (fn (caps)
      (((core/editor/action::task (quote editor/task::test-pkg)) {:caps caps :pkg pkg}) 50))))

(def core/editor/pkg::field
  (fn (resp) (fn (k) (if (core/editor/lint::map? resp) ((core/map::get resp) k) nil))))

(def core/editor/pkg::vec-or-empty (fn (x) (if (core/editor/lint::vec? x) x [])))

(def core/editor/pkg::list-panel-from-response
  (fn (resp)
    (let
      ((f (core/editor/pkg::field resp))
        (reqs (core/editor/pkg::vec-or-empty (f (quote :requirements))))
        (locked (core/editor/pkg::vec-or-empty (f (quote :locked)))))
      {
        :kind (quote :editor/pkg-list-panel)
        :lock (f (quote :lock))
        :locked locked
        :locked-count (core/vec::len locked)
        :ok (f (quote :ok))
        :requirements reqs
        :requirements-count (core/vec::len reqs)})))

(def core/editor/pkg::info-panel-from-response
  (fn (resp)
    (let ((f (core/editor/pkg::field resp)))
      {
        :kind (quote :editor/pkg-info-panel)
        :locked (f (quote :locked))
        :name (f (quote :name))
        :ok (f (quote :ok))
        :requirement (f (quote :requirement))})))

(def core/editor/pkg::status-panel-from-response
  (fn (kind)
    (fn (resp)
      (let
        ((f (core/editor/pkg::field resp))
          (missing (core/editor/pkg::vec-or-empty (f (quote :missing)))))
        {
          :checked (f (quote :checked))
          :kind kind
          :lock (f (quote :lock))
          :lock-h (f (quote :lock-h))
          :locked-count (f (quote :locked-count))
          :missing missing
          :missing-count (core/vec::len missing)
          :ok (f (quote :ok))
          :present (f (quote :present))
          :refs-updated (f (quote :refs-updated))
          :remote (f (quote :remote))
          :snapshot (f (quote :snapshot))
          :total (f (quote :total))
          :updated (f (quote :updated))
          :uploaded (f (quote :uploaded))}))))

(def core/editor/action::pkg-list-panel
  (fn (lock) ((core/effect::map (core/pkg::list lock)) core/editor/pkg::list-panel-from-response)))

(def core/editor/action::pkg-info-panel
