    ((core/effect::map (core/gpk::import in))
      (core/editor/pkg::status-panel-from-response (quote :editor/gpk-import-panel)))))

(def core/editor/action::sync-pull-panel
  (fn (remote)
    (fn (refs)
      (fn (roots)
        (fn (depth)
          (fn (force)
            (fn (set-refs)
              ((core/effect::map ((((((core/sync::pull remote) refs) roots) depth) force) set-refs))
                (core/editor/pkg::status-panel-from-response (quote :editor/sync-pull-panel))))))))))

