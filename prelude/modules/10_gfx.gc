(def core/gfx/ui/runtime::default-text-color [1000000 1000000 1000000 1000000])

(def core/gfx/ui/runtime::map-get-or-nil
  (fn (m)
    (fn (k)
      (if ((core/sym::eq? (core/data::tag m)) (quote :map))
        ((core/map::get m) k)
        nil))))

(def core/gfx/ui/runtime::node-kind
  (fn (node)
    (let ((k ((core/gfx/ui/runtime::map-get-or-nil node) (quote :kind))))
      (if (core/list::is-nil? k)
        "container"
        k))))

(def core/gfx/ui/runtime::node-style
  (fn (node) ((core/gfx/ui/runtime::map-get-or-nil node) (quote :style))))

(def core/gfx/ui/runtime::node-props
