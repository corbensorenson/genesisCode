    (let ((children ((core/gfx/ui/runtime::map-get-or-nil node) (quote :children))))
      (if ((core/sym::eq? (core/data::tag children)) (quote :vec))
        children
        []))))

(def core/gfx/ui/runtime::node-size-w
  (fn (node)
    (fn (parent-w)
      (let ((style (core/gfx/ui/runtime::node-style node))
            (size ((core/gfx/ui/runtime::map-get-or-nil (core/gfx/ui/runtime::node-style node)) (quote :size)))
            (w ((core/gfx/ui/runtime::map-get-or-nil size) (quote :w))))
        (if (core/list::is-nil? w)
          parent-w
          w)))))

