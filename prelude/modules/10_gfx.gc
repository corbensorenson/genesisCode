(def core/gfx/obligation::golden-case
  (fn (suite)
    (fn (name)
      (fn (kind)
        (fn (expect-h)
          (fn (actual-h)
            (fn (expect-png-h)
              (fn (actual-png-h)
                (fn (pixel-width)
                  (fn (pixel-height)
                    (fn (runtime-error)
                      (let
                        ((runtime-ok (if (core/gfx/obligation::str? runtime-error) false true))
                          (hash-ok (if runtime-ok ((core/eq? expect-h) actual-h) false))
                          (need-png (if ((core/sym::eq? (core/data::tag expect-png-h)) (quote :nil)) false true))
                          (png-ok
                            (if runtime-ok
                              (if need-png ((core/eq? expect-png-h) actual-png-h) true)
                              false)))
                        (let
                          ((errors0 [])
                            (errors1
                              (((core/gfx/obligation::errors-push-if errors0)
                                (core/gfx/obligation::str? runtime-error))
                                (if (core/gfx/obligation::str? runtime-error)
                                  runtime-error
                                  "runtime error")))
                            (errors2
                              (((core/gfx/obligation::errors-push-if errors1)
                                (if runtime-ok (if hash-ok false true) false))
                                "golden hash mismatch"))
                            (errors3
                              (((core/gfx/obligation::errors-push-if errors2)
                                (if runtime-ok (if need-png (if png-ok false true) false) false))
                                "golden png hash mismatch")))
                          {
                            :actual-h actual-h
                            :actual-png-h actual-png-h
                            :error runtime-error
                            :errors errors3
                            :expect-h expect-h
                            :expect-png-h expect-png-h
                            :kind kind
                            :name name
                            :ok
                              (if runtime-ok
                                (if hash-ok
                                  (if need-png png-ok true)
                                  false)
                                false)
                            :pixel-height pixel-height
                            :pixel-width pixel-width
                            :suite suite})))))))))))))

