(def core/gfx/obligation::api-stability-analysis
  (fn (exported)
    (fn (expected-exports)
      (fn (tracked)
        (fn (expected-surface-h)
          (fn (surface-h)
            (fn (has-config)
              (fn (missing-defs)
                (let
                  ((compare-exports (if ((core/int::eq? (core/vec::len expected-exports)) 0) false true))
                    (missing
                      (if compare-exports
                        ((core/gfx/obligation::sym-diff expected-exports) exported)
                        []))
                    (extra
                      (if compare-exports
                        ((core/gfx/obligation::sym-diff exported) expected-exports)
                        []))
                    (surface-mismatch
                      (if (core/gfx/obligation::str? expected-surface-h)
                        (if ((core/eq? expected-surface-h) surface-h) false true)
                        false)))
                  (let
                    ((errors0
                       (((core/gfx/obligation::errors-push-if [])
                         (if compare-exports
                           (if ((core/int::eq? (core/vec::len missing)) 0) false true)
                           false))
                         "missing exported gfx symbols"))
                      (errors1
                        (((core/gfx/obligation::errors-push-if errors0)
                          (if compare-exports
                            (if ((core/int::eq? (core/vec::len extra)) 0) false true)
                            false))
                          "unexpected exported gfx symbols"))
                      (errors2
                        (((core/gfx/obligation::errors-push-if errors1)
                          (if ((core/int::eq? (core/vec::len tracked)) 0) true false))
                          "no tracked gfx API exports found"))
                      (errors3
                        (((core/gfx/obligation::errors-push-if errors2) (if has-config false true))
                          "gfx api stability requires gfx.api_exports and/or gfx.api_surface_hash configuration"))
                      (errors4
                        (((core/gfx/obligation::errors-push-if errors3) surface-mismatch)
                          "gfx API surface hash mismatch"))
                      (errors5
                        (((core/gfx/obligation::errors-push-if errors4)
                          (if ((core/int::eq? (core/vec::len missing-defs)) 0) false true))
                          "tracked API symbol has no defining def form")))
                    {
                      :errors errors5
                      :extra extra
                      :missing missing
                      :missing-defs missing-defs
                      :ok ((core/int::eq? (core/vec::len errors5)) 0)}))))))))))

