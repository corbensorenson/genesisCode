(def core/gfx/obligation::sym-diff-loop
  (fn (left)
    (fn (right)
      (fn (i)
        (fn (out)
          (if ((core/int::eq? i) (core/vec::len left))
            out
            (let ((x ((core/vec::get left) i)))
              ((((core/gfx/obligation::sym-diff-loop left) right) ((core/int::add i) 1))
                (if (core/gfx/obligation::sym? x)
                  (if ((core/gfx/obligation::vec-contains-sym? right) x) out ((core/vec::push out) x))
                  out)))))))))

(def core/gfx/obligation::errors-push-if
