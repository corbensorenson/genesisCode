(def core/gfx/ui/runtime::maybe-add-bg
  (fn (node)
    (fn (x)
      (fn (y)
        (fn (w)
          (fn (h)
            (fn (z)
              (fn (draws)
                (let ((bg (core/gfx/ui/runtime::node-bg node)))
                  (if ((core/sym::eq? (core/data::tag bg)) (quote :vec))
                    ((core/vec::push draws) ((((((core/gfx/2d::draw-rect bg) x) y) z) w) h))
                    draws))))))))))

(def core/gfx/ui/runtime::maybe-add-text
  (fn (node)
    (fn (kind)
      (fn (x)
        (fn (y)
          (fn (z)
            (fn (draws)
              (if ((core/eq? kind) "text")
                (let ((text
