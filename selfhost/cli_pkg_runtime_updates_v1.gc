                                              (((core/map::put locked) name) entry))
                                            ((core/int::add updated) 1)))))))
                                (((((core/cli::pkg-update-loop entries) n) ((core/int::add i) 1)) locked)
                                  updated)))))
                        (((((core/cli::pkg-update-loop entries) n) ((core/int::add i) 1)) locked)
                          updated)))
                    (((((core/cli::pkg-update-loop entries) n) ((core/int::add i) 1)) locked)
