(def core/cli::str-drop-prefix
  (fn (s)
    (fn (n)
      (if (if (core/cli::str? s) (core/cli::int? n) false)
        (let ((sb (core/str::to-utf8 s)))
          (let ((sn (core/bytes::len sb)))
            (if ((core/int::lt? sn) n)
              nil
              (core/str::from-utf8 (((core/bytes::slice sb) n) ((core/int::sub sn) n))))))
        nil))))

(def core/cli::pkg-selector-value
  (fn (selector)
    (let ((kind (core/cli::lock-selector-kind selector)))
      (if ((core/sym::eq? kind) (quote :commit))
        (if ((core/cli::str-starts-with? selector) "commit:")
          ((core/cli::str-drop-prefix selector) 7)
          selector)
        (if ((core/sym::eq? kind) (quote :snapshot))
          (if ((core/cli::str-starts-with? selector) "snapshot:")
            ((core/cli::str-drop-prefix selector) 9)
            selector)
          (if ((core/sym::eq? kind) (quote :ref))
            (if ((core/cli::str-starts-with? selector) "ref:")
              ((core/cli::str-drop-prefix selector) 4)
              selector)
            nil))))))

(def core/cli::pkg-update-policy-auto?
