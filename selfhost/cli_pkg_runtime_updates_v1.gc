        false))))

(def core/cli::pkg-resolve-from-commit-program
  (fn (commit-h)
    (fn (registry)
      (fn (resolved-ref)
        (if (core/cli::hash-hex? commit-h)
          ((core/effect::bind (core/cli::store-get-program commit-h))
            (fn (resp)
              (if (core/cli::is-error resp)
                (core/effect::pure resp)
                (let
                  ((commit (core/cli::vcs-validate-commit ((core/map::get resp) (quote :artifact)))))
                  (if (core/cli::is-error commit)
                    (core/effect::pure commit)
                    (core/effect::pure
                      {
                        :commit commit-h
                        :registry registry
                        :resolved_ref resolved-ref
                        :snapshot ((core/map::get commit) (quote :result))}))))))
          (core/effect::pure
            ((core/error::make2 "core/pkg/bad-selector") "commit hash must be 64-hex")))))))

(def core/cli::pkg-resolve-requirement-program
  (fn (requirement)
    (if (core/cli::map? requirement)
      (let
        ((selector ((core/map::get requirement) (quote :selector)))
          (registry ((core/map::get requirement) (quote :registry))))
        (if (core/cli::str? selector)
          (let
            ((kind (core/cli::lock-selector-kind selector))
              (value (core/cli::pkg-selector-value selector)))
            (if ((core/sym::eq? kind) (quote :snapshot))
              (if (core/cli::hash-hex? value)
                (core/effect::pure
                  {
                    :commit nil
                    :registry registry
                    :resolved_ref nil
                    :snapshot value})
                (core/effect::pure
                  ((core/error::make2 "core/pkg/bad-selector") "snapshot hash must be 64-hex")))
              (if ((core/sym::eq? kind) (quote :commit))
                (((core/cli::pkg-resolve-from-commit-program value) registry) nil)
                (if ((core/sym::eq? kind) (quote :ref))
                  ((core/effect::bind (core/cli::refs-get-program value))
                    (fn (rr)
                      (if (core/cli::is-error rr)
                        (core/effect::pure rr)
                        (let ((commit-h ((core/map::get rr) (quote :hash))))
                          (if (core/cli::hash-hex? commit-h)
                            (((core/cli::pkg-resolve-from-commit-program commit-h) registry) value)
                            (core/effect::pure
                              ((core/error::make2 "core/pkg/ref-not-found") "ref is unset")))))))
                  (core/effect::pure
                    ((core/error::make2 "core/pkg/bad-selector") "unsupported selector"))))))
          (core/effect::pure
            ((core/error::make2 "core/pkg/bad-selector") ":selector must be string"))))
      ((core/error::make2 "core/type-error") "core/cli::pkg-resolve-requirement-program expects map"))))

(def core/cli::pkg-update-loop
  (fn (entries)
    (fn (n)
      (fn (i)
        (fn (locked)
          (fn (updated)
            (if ((core/int::eq? i) n)
