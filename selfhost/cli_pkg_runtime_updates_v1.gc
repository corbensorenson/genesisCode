                  (if (if (core/cli::vec? e) ((core/int::eq? (core/vec::len e)) 2) false)
                    (let ((name ((core/vec::get e) 0)) (req ((core/vec::get e) 1)))
                      (if (if (core/cli::str? name) (core/cli::map? req) false)
                        (let
                          ((up ((core/map::get req) (quote :update-policy)))
                            (selector ((core/map::get req) (quote :selector)))
                            (existing ((core/map::get locked) name))
                            (kind (core/cli::lock-selector-kind selector)))
                          (let
                            (
                              (should-update
                                (if (core/cli::pkg-update-policy-auto? up)
                                  (if ((core/sym::eq? kind) (quote :ref)) true false)
                                  false)))
                            (let
                              ((should-resolve (if should-update true (if (core/list::is-nil? existing) true false))))
                              (if should-resolve
