        :source
          "; Patch schema validator for v0.2 (.gcpatch).\n;\n; This module defines a pure validator that returns `true` on success and a sealed ERROR on failure.\n; It is intended to be called by host tooling when running in selfhost frontend mode.\n\n(def selfhost/patch_schema::is-int?\n  (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :int))))\n\n(def selfhost/patch_schema::is-str?\n  (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :str))))\n\n(def selfhost/patch_schema::is-sym?\n  (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :sym))))\n\n(def selfhost/patch_schema::is-vec?\n  (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :vec))))\n\n(def selfhost/patch_schema::is-map?\n  (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :map))))\n\n(def selfhost/patch_schema::err\n  (fn (msg) ((core/error::make2 \"core/patch-schema\") msg)))\n\n(def selfhost/patch_schema::require\n  (fn (cond msg) (if cond true (selfhost/patch_schema::err msg))))\n\n(def selfhost/patch_schema::require-key\n  (fn (m k msg)\n    (let ((v ((core/map::get m) k)))\n      (if (core/list::is-nil? v) (selfhost/patch_schema::err msg) v))))\n\n(def selfhost/patch_schema::validate-path-step\n  (fn (step)\n    (if (selfhost/patch_schema::is-vec? step)\n      (let ((n (core/vec::len step)))\n        (if ((core/int::eq? n) 0)\n          (selfhost/patch_schema::err \"empty path step\")\n          (let ((tag ((core/vec::get step) 0)))\n            (if (selfhost/patch_schema::is-sym? tag)\n              (if ((core/sym::eq? tag) (quote :form))\n                (if ((core/int::eq? n) 2)\n                  (let ((i ((core/vec::get step) 1)))\n                    (if (selfhost/patch_schema::is-int? i)\n                      true\n                      (selfhost/patch_schema::err \":form expects int index\")))\n                  (selfhost/patch_schema::err \":form expects 1 arg\"))\n                (if ((core/sym::eq? tag) (quote :pair-car))\n                  (if ((core/int::eq? n) 1)\n                    true\n                    (selfhost/patch_schema::err \":pair-car expects 0 args\"))\n                  (if ((core/sym::eq? tag) (quote :pair-cdr))\n                    (if ((core/int::eq? n) 1)\n                      true\n                      (selfhost/patch_schema::err \":pair-cdr expects 0 args\"))\n                    (if ((core/sym::eq? tag) (quote :vec))\n                      (if ((core/int::eq? n) 2)\n                        (let ((i ((core/vec::get step) 1)))\n                          (if (selfhost/patch_schema::is-int? i)\n                            true\n                            (selfhost/patch_schema::err \":vec expects int index\")))\n                        (selfhost/patch_schema::err \":vec expects 1 arg\"))\n                      (if ((core/sym::eq? tag) (quote :map))\n                        (if ((core/int::eq? n) 2)\n                          true\n                          (selfhost/patch_schema::err \":map expects 1 arg\"))\n                        (selfhost/patch_schema::err \"unknown path step tag\"))))))\n              (selfhost/patch_schema::err \"path step tag must be symbol\")))))\n      (selfhost/patch_schema::err \":path step must be vector\"))))\n\n(def selfhost/patch_schema::validate-path\n  (fn (path)\n    (if (selfhost/patch_schema::is-vec? path)\n      (let ((len (core/vec::len path)))\n        ((selfhost/patch_schema::validate-path-loop path len) 0))\n      (selfhost/patch_schema::err \":path must be vector\"))))\n\n(def selfhost/patch_schema::validate-path-loop\n  (fn (path len)\n    (fn (i)\n      (if ((core/int::eq? i) len)\n        true\n        (let ((step ((core/vec::get path) i)))\n          (let ((r (selfhost/patch_schema::validate-path-step step)))\n            (if (core/error::is? r)\n              r\n              ((selfhost/patch_schema::validate-path-loop path len) ((core/int::add i) 1)))))))))\n\n(def selfhost/patch_schema::validate-op-replace-node\n  (fn (opm)\n    (let ((mp (selfhost/patch_schema::require-key opm (quote :module-path) \"replace-node missing :module-path\")))\n      (if (core/error::is? mp)\n        mp\n        (if (selfhost/patch_schema::is-str? mp)\n          (let ((path (selfhost/patch_schema::require-key opm (quote :path) \"replace-node missing :path\")))\n            (if (core/error::is? path)\n              path\n              (let ((r (selfhost/patch_schema::validate-path path)))\n                (if (core/error::is? r)\n                  r\n                  (let ((newv (selfhost/patch_schema::require-key opm (quote :new) \"replace-node missing :new\")))\n                    (if (core/error::is? newv) newv true))))))\n          (selfhost/patch_schema::err \"replace-node :module-path must be string\"))))))\n\n(def selfhost/patch_schema::validate-op-add-module\n  (fn (opm)\n    (let ((mp (selfhost/patch_schema::require-key opm (quote :module-path) \"add-module missing :module-path\")))\n      (if (core/error::is? mp)\n        mp\n        (if (selfhost/patch_schema::is-str? mp)\n          (let ((content (selfhost/patch_schema::require-key opm (quote :content) \"add-module missing :content\")))\n            (if (core/error::is? content)\n              content\n              (if (selfhost/patch_schema::is-str? content)\n                true\n                (if (selfhost/patch_schema::is-vec? content)\n                  true\n                  (selfhost/patch_schema::err \"add-module :content must be string or vector\")))))\n          (selfhost/patch_schema::err \"add-module :module-path must be string\"))))))\n\n(def selfhost/patch_schema::validate-op-remove-module\n  (fn (opm)\n    (let ((mp (selfhost/patch_schema::require-key opm (quote :module-path) \"remove-module missing :module-path\")))\n      (if (core/error::is? mp)\n        mp\n        (if (selfhost/patch_schema::is-str? mp)\n          true\n          (selfhost/patch_schema::err \"remove-module :module-path must be string\"))))))\n\n(def selfhost/patch_schema::validate-op-update-manifest\n  (fn (opm)\n    ; `:update-manifest` is intentionally conservative: validate only basic shape and a small set of known fields.\n    (let ((setv ((core/map::get opm) (quote :set))))\n      (if (core/list::is-nil? setv)\n        true\n        (if (selfhost/patch_schema::is-map? setv)\n          true\n          (selfhost/patch_schema::err \":set must be a map\"))))))\n\n(def selfhost/patch_schema::validate-op\n  (fn (op)\n    (if (selfhost/patch_schema::is-map? op)\n      (let ((op_sym ((core/map::get op) (quote :op))))\n        (if (core/list::is-nil? op_sym)\n          (selfhost/patch_schema::err \"missing :op\")\n          (if (selfhost/patch_schema::is-sym? op_sym)\n            (if ((core/sym::eq? op_sym) (quote :replace-node))\n              (selfhost/patch_schema::validate-op-replace-node op)\n              (if ((core/sym::eq? op_sym) (quote :add-module))\n                (selfhost/patch_schema::validate-op-add-module op)\n                (if ((core/sym::eq? op_sym) (quote :remove-module))\n                  (selfhost/patch_schema::validate-op-remove-module op)\n                  (if ((core/sym::eq? op_sym) (quote :update-manifest))\n                    (selfhost/patch_schema::validate-op-update-manifest op)\n                    (selfhost/patch_schema::err \"unknown :op\")))))\n            (selfhost/patch_schema::err \":op must be a symbol\"))))\n      (selfhost/patch_schema::err \"op must be a map\"))))\n\n(def selfhost/patch_schema::validate-ops\n  (fn (ops)\n    (if (selfhost/patch_schema::is-vec? ops)\n      (let ((len (core/vec::len ops)))\n        ((selfhost/patch_schema::validate-ops-loop ops len) 0))\n      (selfhost/patch_schema::err \":ops must be a vector\"))))\n\n(def selfhost/patch_schema::validate-ops-loop\n  (fn (ops len)\n    (fn (i)\n      (if ((core/int::eq? i) len)\n        true\n        (let ((op ((core/vec::get ops) i)))\n          (let ((r (selfhost/patch_schema::validate-op op)))\n            (if (core/error::is? r)\n              r\n              ((selfhost/patch_schema::validate-ops-loop ops len) ((core/int::add i) 1)))))))))\n\n(def core/cli::validate-patch\n  (fn (t)\n    (if (selfhost/patch_schema::is-map? t)\n      (let ((v ((core/map::get t) (quote :version))))\n        (if (selfhost/patch_schema::is-int? v)\n          (if ((core/int::eq? v) 1)\n            (let ((intent ((core/map::get t) (quote :intent))))\n              (if (selfhost/patch_schema::is-str? intent)\n                (let ((prov ((core/map::get t) (quote :provenance))))\n                  (if (selfhost/patch_schema::is-map? prov)\n                    (selfhost/patch_schema::validate-ops ((core/map::get t) (quote :ops)))\n                    (selfhost/patch_schema::err \":provenance must be a map\")))\n                (selfhost/patch_schema::err \":intent must be a string\")))\n            (selfhost/patch_schema::err \":version must be 1\"))\n          (selfhost/patch_schema::err \":version must be an int\")))\n      (selfhost/patch_schema::err \"patch must be a map\"))))\n"
