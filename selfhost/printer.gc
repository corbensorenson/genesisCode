                    ((selfhost/printer::append-last out) ")")
                    ((((selfhost/printer::fmt-list-soft-tail items) indent) hc) out)))))))))))

(def selfhost/printer::fmt-list-can-take-second?
  (fn (items)
    (fn (first)
      (if ((selfhost/printer::int::le? (core/vec::len items)) 1)
        false
        (let ((h1 (selfhost/printer::single-line ((core/vec::get items) 1))))
