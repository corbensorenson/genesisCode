(def selfhost/printer::is-error core/error::is?)

(def selfhost/printer::tag
  (fn (x)
    (let ((tg (core/data::tag x)))
      (if (selfhost/printer::is-error tg)
        (let ((vn (core/vec::len x)))
          (if (selfhost/printer::is-error vn)
            (let ((mn (core/map::len x)))
              (if (selfhost/printer::is-error mn) tg (quote :map)))
            (quote :vec)))
        tg))))

(def selfhost/printer::INDENT 2)
(def selfhost/printer::MAX_WIDTH 100)

(def selfhost/printer::spaces (fn (n) ((core/str::repeat " ") n)))

(def selfhost/printer::list-rev (fn (xs) ((selfhost/printer::list-rev2 xs) nil)))
(def selfhost/printer::list-rev2
