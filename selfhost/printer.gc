      (let ((n (core/vec::len items)))
        (if ((core/int::eq? n) 0)
          (selfhost/printer::vec1 ((core/str::concat (selfhost/printer::spaces indent)) "()"))
          (let ((head0 (selfhost/printer::single-line ((core/vec::get items) 0))))
            (if (core/list::is-nil? head0)
              ((selfhost/printer::fmt-list-multi-head-hard items) indent)
              (((selfhost/printer::fmt-list-multi-head-soft items) indent) head0))))))))

(def selfhost/printer::fmt-list-multi-head-hard
  (fn (items)
    (fn (indent)
