(def selfhost/printer::fmt-list-multi-head-hard2
  (fn (items)
    (fn (indent)
      (fn (i)
        (fn (out)
          (if ((core/int::lt? i) (core/vec::len items))
            (let
              (
                (lines
                  ((selfhost/printer::fmt-term ((core/vec::get items) i))
                    ((core/int::add indent) selfhost/printer::INDENT))))
