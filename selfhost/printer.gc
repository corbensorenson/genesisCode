        acc
        (((selfhost/printer::list-rev2 (core/pair::cdr xs)) ((core/pair::cons (core/pair::car xs)) acc)))))))

; out_rev is reverse(output_so_far). Appending lines (forward order) is done by consing them onto out_rev.
(def selfhost/printer::append-lines-to-rev
  (fn (out_rev)
    (fn (lines)
      (if (core/list::is-nil? lines)
        out_rev
        (((selfhost/printer::append-lines-to-rev ((core/pair::cons (core/pair::car lines)) out_rev))
          (core/pair::cdr lines)))))))

(def selfhost/printer::join-lines
