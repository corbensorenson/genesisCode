                  ((selfhost/printer::append-last out2) ")")
                  ((((selfhost/printer::fmt-list-multi-head-hard2 items) indent) ((core/int::add i) 1))
                    out2))))
            out))))))

(def selfhost/printer::fmt-list-multi-head-soft
  (fn (items)
    (fn (indent)
      (fn (head0)
        (let ((head_count 1))
          (let
            ((first ((core/str::concat (selfhost/printer::spaces indent)) ((core/str::concat "(") head0))))
            (let ((hc (if ((selfhost/printer::fmt-list-can-take-second? items) first) 2 1)))
              (let
                (
                  (first2
