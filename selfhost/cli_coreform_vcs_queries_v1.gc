                ((seen ((core/map::get state) (quote :seen)))
                  (h ((core/vec::get stack) ((core/int::sub (core/vec::len stack)) 1)))
                  (rest
                    ((core/cli::vcs-log::vec-take stack) ((core/int::sub (core/vec::len stack)) 1))))
                (if (core/list::is-nil? ((core/map::get seen) h))
                  ((core/effect::bind (core/cli::store-get-program h))
                    (fn (resp)
                      (if (core/cli::is-error resp)
                        (core/effect::pure resp)
                        (let
                          ((c (core/cli::vcs-validate-commit ((core/map::get resp) (quote :artifact)))))
                          (if (core/cli::is-error c)
                            (core/effect::pure c)
                            (let
                              ((parents ((core/map::get c) (quote :parents)))
                                (stack2
                                  ((core/cli::vec-append rest)
                                    (core/cli::vcs-log::vec-reverse parents)))
                                (seen2 (((core/map::put seen) h) true))
                                (commits2
                                  ((core/vec::push commits) ((core/cli::vcs-log::entry h) c)))
                                (state2
                                  {
                                    :commits commits2
                                    :seen seen2
                                    :stack stack2
                                    :truncated false}))
                              ((core/cli::vcs-log::loop state2) max)))))))
                  (
                    (core/cli::vcs-log::loop
                      {
                        :commits commits
                        :seen seen
                        :stack rest
                        :truncated ((core/map::get state) (quote :truncated))})
                    max))))))))))

(def core/cli::vcs-log-program
  (fn (req)
    (if (core/cli::map? req)
      (let ((root0 ((core/map::get req) (quote :root))) (max0 ((core/map::get req) (quote :max))))
        (let ((max (if (core/cli::int? max0) max0 1000)))
          ((core/effect::bind (core/cli::vcs-log::resolve-root root0))
            (fn (resolved)
              (if (core/cli::is-error resolved)
                (core/effect::pure resolved)
                (
                  (core/effect::bind
                    (
                      (core/cli::vcs-log::loop
                        {
                          :commits []
                          :seen {}
                          :stack ((core/vec::push []) resolved)
                          :truncated false})
                      max))
                  (fn (state)
                    (if (core/cli::is-error state)
                      (core/effect::pure state)
                      (core/effect::pure
                        {
                          :commits ((core/map::get state) (quote :commits))
                          :ok true
                          :root resolved
                          :truncated ((core/map::get state) (quote :truncated))})))))))))
      ((core/error::make2 "core/type-error") "core/cli::vcs-log-program expects map"))))

