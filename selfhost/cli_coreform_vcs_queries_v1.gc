(def core/cli::vcs-log::resolve-root
  (fn (root)
    (if (core/cli::str? root)
      (if ((core/cli::str-starts-with? root) "refs/")
        ((core/effect::bind (core/cli::refs-get-program root))
          (fn (resp)
            (if (core/cli::is-error resp)
              (core/effect::pure resp)
              (let ((h ((core/map::get resp) (quote :hash))))
                (if (core/cli::str? h)
                  (core/effect::pure h)
                  (core/effect::pure
                    ((core/error::make2 "core/vcs/ref-not-found")
                      ((core/str::concat "ref not found: ") root))))))))
        (if (core/cli::hash-hex? root)
          (core/effect::pure root)
          (core/effect::pure
            ((core/error::make2 "core/vcs/bad-root") "root must be a 64-hex commit hash or refs/..."))))
      (core/effect::pure
        ((core/error::make2 "core/vcs/bad-root") "root must be a 64-hex commit hash or refs/...")))))

(def core/cli::vcs-log::loop
  (fn (state)
    (fn (max)
      (let ((commits ((core/map::get state) (quote :commits))))
        (if ((core/int::eq? (core/vec::len commits)) max)
          (core/effect::pure (((core/map::put state) (quote :truncated)) true))
          (let ((stack ((core/map::get state) (quote :stack))))
