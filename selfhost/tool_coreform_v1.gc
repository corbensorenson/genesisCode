(def selfhost/tool::is-error core/error::is?)

; v0.2 selfhost toolchain surface:
; The tool operations are CoreForm-level functions, but delegate to the canonical Rust CoreForm
; frontend for performance and for guaranteed conformance.

(def selfhost/tool::fmt-module (fn (src) (core/coreform::fmt-module src)))

(def selfhost/tool::hash-module-src (fn (src) (core/coreform::hash-module-src src)))

