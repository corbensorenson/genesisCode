(def selfhost/parse::is-error core/error::is?)

; v0.2 bootstrap selfhost frontend:
; Use the canonical Rust CoreForm parser, but expose it through stable CoreForm-level names.
; Errors are protocol ERROR values (unforgeable) with :error/code and :error/context{:at ...}.

(def selfhost/parse::parse-term (fn (src) (core/coreform::parse-term src)))

(def selfhost/parse::parse-module (fn (src) (core/coreform::parse-module src)))

