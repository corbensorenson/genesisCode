                            (core/effect::pure value-h)
                            (if (core/cli::hash-hex? value-h)
                              ((core/effect::bind ((((core/cli::vcs-blame-loop start-h) sym) value-h) {}))
                                (fn (blame-h)
                                  (if (core/cli::is-error blame-h)
                                    (core/effect::pure blame-h)
                                    ((core/effect::bind (core/cli::vcs-load-commit blame-h))
                                      (fn (loaded)
