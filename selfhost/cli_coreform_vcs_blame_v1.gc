                                          (core/effect::pure loaded)
                                          (let ((c ((core/map::get loaded) (quote :commit))))
                                            (core/effect::pure
                                              {
                                                :commit blame-h
                                                :ok true
                                                :path path
                                                :query-snapshot query-snapshot
                                                :snapshot ((core/map::get c) (quote :result))
                                                :sym sym
                                                :value value-h}))))))))
                              (core/effect::pure
                                ((core/error::make2 "core/vcs/symbol-not-found")
                                  ((core/str::concat "symbol not found in snapshot: ") sym)))))))))))))))
      ((core/error::make2 "core/type-error") "core/cli::vcs-blame-program expects map"))))

(def core/cli::vcs-why-program
  (fn (req)
    (if (core/cli::map? req)
      (let
        ((sym (core/cli::sym-or-str->str ((core/map::get req) (quote :sym))))
