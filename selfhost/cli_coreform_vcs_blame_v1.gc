(def core/cli::vcs-load-commit
  (fn (h)
    (if (core/cli::hash-hex? h)
      ((core/effect::bind (core/cli::store-get-program h))
        (fn (resp)
          (if (core/cli::is-error resp)
            (core/effect::pure resp)
            (let ((commit (core/cli::vcs-validate-commit ((core/map::get resp) (quote :artifact)))))
              (if (core/cli::is-error commit)
                (core/effect::pure commit)
                (core/effect::pure {:commit commit :hash h}))))))
      (core/effect::pure ((core/error::make2 "core/vcs/bad-payload") ":commit must be 64-hex hash")))))

(def core/cli::vcs-load-snapshot
  (fn (h)
    (if (core/cli::hash-hex? h)
      ((core/effect::bind (core/cli::store-get-program h))
        (fn (resp)
