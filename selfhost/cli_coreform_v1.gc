(def core/cli::is-error core/error::is?)

(def core/cli::sym? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :sym))))

(def core/cli::vec? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :vec))))

(def core/cli::map? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :map))))

(def core/cli::pair? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :pair))))

(def core/cli::str? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :str))))

(def core/cli::bool? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :bool))))

(def core/cli::int? (fn (x) ((core/sym::eq? (core/data::tag x)) (quote :int))))

(def core/cli::str-or-nil? (fn (x) (if (core/list::is-nil? x) true (core/cli::str? x))))

(def core/cli::keygen-request
  (fn (req)
    (if (core/cli::map? req)
      (let ((out ((core/map::get req) (quote :out))))
        (if (core/cli::str? out)
          {:out out}
          ((core/error::make2 "core/type-error") "core/cli::keygen-request expects :out string")))
      ((core/error::make2 "core/type-error") "core/cli::keygen-request expects map"))))

(def core/cli::sign-request
  (fn (req)
    (if (core/cli::map? req)
      (let
        ((pkg ((core/map::get req) (quote :pkg))) (key ((core/map::get req) (quote :key)))
          (acceptance ((core/map::get req) (quote :acceptance)))
          (signatures ((core/map::get req) (quote :signatures))))
        (if (if (core/cli::str? pkg) (core/cli::str? key) false)
          (if (core/cli::str-or-nil? acceptance)
            (if (core/cli::str-or-nil? signatures)
              {
                :acceptance acceptance
                :key key
                :pkg pkg
                :signatures signatures}
              ((core/error::make2 "core/type-error")
                "core/cli::sign-request expects :signatures string or nil"))
            ((core/error::make2 "core/type-error")
              "core/cli::sign-request expects :acceptance string or nil"))
          ((core/error::make2 "core/type-error")
            "core/cli::sign-request expects :pkg and :key strings")))
      ((core/error::make2 "core/type-error") "core/cli::sign-request expects map"))))

