(def core/cli::verify-request
  (fn (req)
    (if (core/cli::map? req)
      (let
        ((pkg ((core/map::get req) (quote :pkg)))
          (acceptance ((core/map::get req) (quote :acceptance)))
          (policy ((core/map::get req) (quote :policy)))
          (signatures ((core/map::get req) (quote :signatures)))
          (scan-store ((core/map::get req) (quote :scan-store))))
        (if (core/cli::str? pkg)
          (if (if (core/cli::str-or-nil? acceptance) (core/cli::str-or-nil? policy) false)
            (if (core/cli::str-or-nil? signatures)
              (if (core/cli::bool? scan-store)
                {
                  :acceptance acceptance
                  :pkg pkg
                  :policy policy
                  :scan-store scan-store
                  :signatures signatures}
                ((core/error::make2 "core/type-error")
                  "core/cli::verify-request expects :scan-store bool"))
              ((core/error::make2 "core/type-error")
                "core/cli::verify-request expects :signatures string or nil"))
            ((core/error::make2 "core/type-error")
              "core/cli::verify-request expects :acceptance and :policy as string or nil"))
          ((core/error::make2 "core/type-error") "core/cli::verify-request expects :pkg string")))
      ((core/error::make2 "core/type-error") "core/cli::verify-request expects map"))))

