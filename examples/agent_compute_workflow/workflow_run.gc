(def stage/compile
  ((core/kit/pipeline::stage-v1 "compile")
    (fn (_state)
      ((core/effect::bind (((core/task::spawn "scope/workflow") "compile") {:job "compile"}))
        (fn (spawn-resp)
          (core/task::await ((core/map::get spawn-resp) (quote :task-id))))))))

(def stage/gpu-buffer-roundtrip
  ((core/kit/pipeline::stage-v1 "gpu-buffer-roundtrip")
    (fn (_state)
      ((core/effect::bind (core/gfx/gpu::create-buffer {:size 8}))
        (fn (created)
          (let ((rid ((core/map::get created) (quote :id))))
            ((core/effect::bind (((core/gfx/gpu::write-buffer rid) 0) b"ABCDEFGH"))
              (fn (_w)
                ((core/effect::bind (((core/gfx/gpu::read-buffer rid) 0) 8))
                  (fn (read)
                    ((core/effect::bind (core/gfx/gpu::destroy-resource rid))
                      (fn (_d) (core/effect::pure read)))))))))))))

(def pipeline/stages
  ((core/vec::push ((core/vec::push []) stage/compile)) stage/gpu-buffer-roundtrip))

(def pipeline/spec (((core/kit/pipeline::spec-v1 "agent_compute_workflow") nil) pipeline/stages))

(def prog (core/kit/pipeline::run-spec pipeline/spec))

prog
