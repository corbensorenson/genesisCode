(def workflow/step
  (fn (n)
    (fn (frames)
      (if ((core/int::eq? n) 0)
        (core/effect::pure {:ok true :frames frames})
        ((core/effect::bind
           (core/effect::perform
             (quote gfx/time::frame-tick)
             {:scope "agent-gfx-loop"}
             (fn (x) (core/effect::pure x))))
          (fn (_tick)
            (((workflow/step ((core/int::sub n) 1)) ((core/int::add frames) 1)))))))))

(def prog ((workflow/step 64) 0))

prog
