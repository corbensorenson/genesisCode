(def stage/compile
  ((core/kit/pipeline::stage-v1 "compile")
    (fn (_state)
      ((core/effect::bind (((core/task::spawn "scope/workflow") "compile") {:job "compile"}))
        (fn (spawn-resp)
          (core/task::await ((core/map::get spawn-resp) (quote :task-id))))))))

(def stage/compute-submit
  ((core/kit/pipeline::stage-v1 "compute-submit")
    (fn (_state)
      (core/gpu/compute::submit
        {
          :passes [{
            :dispatch {:x 128 :y 1 :z 1}
            :kernel "bench/vecadd"
            :bindings [{:buffer "in-a"} {:buffer "in-b"} {:buffer "out"}]
          }]
        }))))

(def pipeline/stages ((core/vec::push ((core/vec::push []) stage/compile)) stage/compute-submit))

(def pipeline/spec (((core/kit/pipeline::spec-v1 "agent_gpu_compute_workflow") nil) pipeline/stages))

(def prog (core/kit/pipeline::run-spec pipeline/spec))

prog
