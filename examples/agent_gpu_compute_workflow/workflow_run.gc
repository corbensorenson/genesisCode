(def prog
  ((core/effect::bind (((core/task::spawn "scope/workflow") "compile") {:job "compile"}))
    (fn (spawn-resp)
      (let ((tid ((core/map::get spawn-resp) (quote :task-id))))
        ((core/effect::bind (core/task::await tid))
          (fn (_awaited)
            (core/effect::perform
              'gpu/compute::submit
              {
                :graph {
                  :passes [{
                    :dispatch {:x 128 :y 1 :z 1}
                    :kernel "bench/vecadd"
                    :bindings [{:buffer "in-a"} {:buffer "in-b"} {:buffer "out"}]
                  }]
                }
              }
              (fn (resp) (core/effect::pure resp)))))))))

prog
