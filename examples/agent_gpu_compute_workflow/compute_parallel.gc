(def ::meta
  (quote
    {
      :caps [
        core/task::spawn
        core/task::await
        core/task::status
        gpu/compute::submit
      ]
      :exports [pkg/agent_gpu_compute::tests]
      :types {pkg/agent_gpu_compute::tests ?}
    }))

(def pkg/agent_gpu_compute::task-program
  ((core/effect::bind (((core/task::spawn "scope/main") "build") {:job "compile"}))
    (fn (spawn-resp)
      (let ((tid ((core/map::get spawn-resp) (quote :task-id))))
        ((core/effect::bind (core/task::status tid))
          (fn (_status)
            (core/task::await tid)))))))

(def pkg/agent_gpu_compute::compute-program
  (core/effect::perform
    'gpu/compute::submit
    {
      :graph {
        :passes [{
          :dispatch {:x 128 :y 1 :z 1}
          :kernel "bench/vecadd"
          :bindings [{:buffer "in-a"} {:buffer "in-b"} {:buffer "out"}]
        }]
      }
    }
    (fn (resp) (core/effect::pure resp))))

(def pkg/agent_gpu_compute::tests
  {
    "task-roundtrip" {:body (fn (_) pkg/agent_gpu_compute::task-program)}
    "gpu-compute-submit" {:body (fn (_) pkg/agent_gpu_compute::compute-program)}
  })

pkg/agent_gpu_compute::tests
