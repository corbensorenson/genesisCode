(def prog
  ((core/effect::bind
     (core/effect::perform
       (quote io/net::http-request)
       {:url "https://example.test/health" :method "GET" :headers []}
       (fn (x) (core/effect::pure x))))
    (fn (http-resp)
      ((core/effect::bind
         (core/effect::perform
           (quote sys/process::exec)
           {:program "echo" :args ["pong"]}
           (fn (x) (core/effect::pure x))))
        (fn (proc-resp)
          (core/effect::pure
            {
              :ok true
              :http-status ((core/map::get http-resp) (quote :status))
              :exit ((core/map::get proc-resp) (quote :exit))
            }))))))

prog
