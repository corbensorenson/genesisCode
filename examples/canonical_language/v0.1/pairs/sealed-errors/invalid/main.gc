(let ((error-value
        (seal
          {:error/code "canonical/expected"
           :error/context {:example "sealed-errors"}
           :error/message "expected example error"}
          0)))
  (if (core/protocol::is-error error-value)
    ((core/map::get (core/protocol::unerror error-value)) (quote :error/code))
    "not-sealed"))
