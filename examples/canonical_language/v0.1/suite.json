        "root": "examples/canonical_language/v0.1/pairs/contracts/valid",
        "files": [
          {
            "path": "main.gc",
            "sha256": "5f27ebca04407bc97d3dd3f29bafcb5e3aeb00fb80cc387f9e4eb65166eb2b4f"
          }
        ],
        "expectedOutcome": "accepted",
        "steps": [
          {
            "id": "execute",
            "argv": [
              "--json",
              "eval",
              "main.gc"
            ],
            "expect": {
              "exitCode": 0,
              "ok": true,
              "kind": "genesis/eval-v0.2",
              "assertions": [
                {
                  "pointer": "/data/value",
                  "operator": "equals",
                  "value": "42"
                }
              ]
            }
          }
        ]
      },
      "invalid": {
        "root": "examples/canonical_language/v0.1/pairs/contracts/invalid",
        "files": [
          {
            "path": "main.gc",
            "sha256": "d1bbcacb8d7b8b866ed0c11ccfc13b5f0fc1707fc455fd1cccf7f535559a2eb9"
          }
        ],
        "expectedOutcome": "sealed-rejection",
        "steps": [
          {
            "id": "execute",
            "argv": [
              "--json",
              "eval",
              "main.gc"
            ],
            "expect": {
              "exitCode": 0,
              "ok": true,
              "kind": "genesis/eval-v0.2",
              "assertions": [
                {
                  "pointer": "/data/value",
                  "operator": "contains",
                  "value": "unhandled (msg canonical/contracts::missing nil)"
