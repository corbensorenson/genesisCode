              ]
            }
          }
        ]
      },
      "mutation": {
        "kind": "replace-once",
        "path": "main.gc",
        "before": "canonical/contracts::ok)) nil",
        "after": "canonical/contracts::missing)) nil"
      },
      "repair": "Restore the message operation to canonical/contracts::ok; do not add a catch-all contract branch."
    },
